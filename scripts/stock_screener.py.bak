def fetch_sector_flows():
    url = ('https://push2.eastmoney.com/api/qt/clist/get?pn=1&pz=200&po=1&np=1'
           '&fltt=2&invt=2&fid=f62&fs=m:90+t:2'
           '&fields=f12,f14,f2,f3,f62,f184,f66,f69,f72,f75,f78,f81,f84,f87')
    try:
        data = _get_json(url)
        diff = data.get('data', {}).get('diff', [])
        return [
            {
                'code': item.get('f12', ''),
                'name': item.get('f14', ''),
                'pct': _safe_float(item.get('f3'), 0.0),
                'mainNet': _safe_float(item.get('f62'), 0.0),
                'mainPct': _safe_float(item.get('f184'), 0.0),
            }
            for item in diff
        ]
    except Exception as exc:
        print(f'[stock_screen] 获取板块资金流失败: {exc}')
        return []


def load_hot_events():
    path = os.path.join(DATA_DIR, 'hot_events.json')
    if not os.path.exists(path):
        return [], []
    try:
        with open(path, 'r', encoding='utf-8') as handle:
            data = json.load(handle)
        return data.get('events', []), data.get('heatmap', [])
    except Exception:
        return [], []


def fetch_a_share_universe():
    fields = 'f12,f14,f2,f3,f5,f6,f8,f15,f16,f17,f20,f21,f100'
    fs = 'm:0+t:6,m:0+t:80,m:1+t:2,m:1+t:23'
    result = []
    page = 1
    while True:
        url = ('https://push2.eastmoney.com/api/qt/clist/get'
               f'?pn={page}&pz=500&po=1&np=1&fltt=2&invt=2&fid=f3&fs={fs}&fields={fields}')
        try:
            data = _get_json(url)
            diff = data.get('data', {}).get('diff', [])
        except Exception as exc:
            print(f'[stock_screen] 股票列表第{page}页失败: {exc}')
            break

        if not diff:
            break

        for item in diff:
            code = str(item.get('f12', '')).strip()
            name = str(item.get('f14', '')).strip()
            if not code or not name:
                continue
            if 'ST' in name.upper() or '退' in name:
                continue
            result.append({
                'code': code,
                'name': name,
                'latest': _safe_float(item.get('f2'), 0.0),
                'pct': _safe_float(item.get('f3'), 0.0),
                'volume': _safe_float(item.get('f5'), 0.0),
                'amount': _safe_float(item.get('f6'), 0.0),
                'turnover': _safe_float(item.get('f8'), 0.0),
                'high': _safe_float(item.get('f15'), 0.0),
                'low': _safe_float(item.get('f16'), 0.0),
                'open': _safe_float(item.get('f17'), 0.0),
                'marketCap': _safe_float(item.get('f20'), 0.0),
                'floatCap': _safe_float(item.get('f21'), 0.0),
                'industry': str(item.get('f100', '') or '其他').strip(),
            })

        if len(diff) < 500:
            break
        page += 1
        time.sleep(0.08)

    return result


def fetch_stock_kline(stock, limit=140):
    url = ('https://push2his.eastmoney.com/api/qt/stock/kline/get'
           f'?secid={_secid(stock["code"])}&fields1=f1,f2,f3,f4,f5,f6'
           '&fields2=f51,f52,f53,f54,f55,f56,f57,f58,f59,f60,f61'
           f'&klt=101&fqt=1&end=20500101&lmt={limit}')
    data = _get_json(url)
    klines = data.get('data', {}).get('klines', [])
    rows = []
    for line in klines:
        parts = line.split(',')
        if len(parts) < 7:
            continue
        rows.append({
            'date': parts[0],
            'open': _safe_float(parts[1]),
            'close': _safe_float(parts[2]),
            'high': _safe_float(parts[3]),
            'low': _safe_float(parts[4]),
            'volume': _safe_float(parts[5]),
            'amount': _safe_float(parts[6]),
            'pct': _safe_float(parts[8]) if len(parts) > 8 else 0.0,
            'turnover': _safe_float(parts[10]) if len(parts) > 10 else 0.0,
        })
    return rows


def moving_average(values, period):
    out = [None] * len(values)
    if len(values) < period:
        return out
    window_sum = sum(values[:period])
    out[period - 1] = window_sum / period
    for index in range(period, len(values)):
        window_sum += values[index] - values[index - period]
        out[index] = window_sum / period
    return out


def ema(values, period):
    out = []
    if not values:
        return out
    alpha = 2 / (period + 1)
    prev = values[0]
    for value in values:
        prev = alpha * value + (1 - alpha) * prev
        out.append(prev)
    return out


def calc_rsi(values, period=14):
    if len(values) <= period:
        return [None] * len(values)
    rsis = [None] * len(values)
    gains = []
    losses = []
    for idx in range(1, period + 1):
        delta = values[idx] - values[idx - 1]
        gains.append(max(delta, 0))
        losses.append(abs(min(delta, 0)))
    avg_gain = sum(gains) / period
    avg_loss = sum(losses) / period
    rs = avg_gain / avg_loss if avg_loss else math.inf
    rsis[period] = 100 - (100 / (1 + rs))
    for idx in range(period + 1, len(values)):
        delta = values[idx] - values[idx - 1]
        gain = max(delta, 0)
        loss = abs(min(delta, 0))
        avg_gain = (avg_gain * (period - 1) + gain) / period
        avg_loss = (avg_loss * (period - 1) + loss) / period
        rs = avg_gain / avg_loss if avg_loss else math.inf
        rsis[idx] = 100 - (100 / (1 + rs))
    return rsis


def calc_macd(values):
    ema12 = ema(values, 12)
    ema26 = ema(values, 26)
    dif = [a - b for a, b in zip(ema12, ema26)]
    dea = ema(dif, 9)
    hist = [(a - b) * 2 for a, b in zip(dif, dea)]
    return dif, dea, hist


def calc_volatility(values, days=20):
    if len(values) < days + 1:
        return 0.0
    returns = []
    for idx in range(len(values) - days, len(values)):
        prev = values[idx - 1]
        curr = values[idx]
        if prev > 0:
            returns.append((curr - prev) / prev)
    if len(returns) < 2:
        return 0.0
    return statistics.pstdev(returns)


def local_extrema(values, mode='low'):
    found = []
    for idx in range(2, len(values) - 2):
        sample = values[idx - 2:idx + 3]
        target = values[idx]
        if mode == 'low' and target == min(sample):
            found.append((idx, target))
        if mode == 'high' and target == max(sample):
            found.append((idx, target))
    return found


def analyze_structure(stock, rows, market_ctx):
    if len(rows) < 80:
        return None

    closes = [row['close'] for row in rows]
    highs = [row['high'] for row in rows]
    lows = [row['low'] for row in rows]
    opens = [row['open'] for row in rows]
    volumes = [row['volume'] for row in rows]
    amounts = [row['amount'] for row in rows]

    latest = rows[-1]
    prev = rows[-2]
    ma5 = moving_average(closes, 5)
    ma20 = moving_average(closes, 20)
    ma60 = moving_average(closes, 60)
    rsi = calc_rsi(closes, 14)
    dif, dea, hist = calc_macd(closes)

    latest_ma5 = ma5[-1]
    latest_ma20 = ma20[-1]
    latest_ma60 = ma60[-1]
    if not latest_ma20 or not latest_ma60:
        return None

    avg_vol5 = sum(volumes[-5:]) / 5
    avg_vol20 = sum(volumes[-20:]) / 20
    avg_amt20 = sum(amounts[-20:]) / 20 if sum(amounts[-20:]) else 0.0
    chg5 = ((closes[-1] - closes[-6]) / closes[-6] * 100) if closes[-6] else 0.0
    chg20 = ((closes[-1] - closes[-21]) / closes[-21] * 100) if closes[-21] else 0.0
    drawdown20 = ((max(highs[-20:]) - closes[-1]) / max(highs[-20:]) * 100) if max(highs[-20:]) else 0.0
    volatility = calc_volatility(closes)

    prev_body_low = min(prev['open'], prev['close'])
    prev_body_high = max(prev['open'], prev['close'])
    latest_body_low = min(latest['open'], latest['close'])
    latest_body_high = max(latest['open'], latest['close'])
    latest_body = abs(latest['close'] - latest['open'])
    latest_range = max(latest['high'] - latest['low'], 1e-6)
    lower_shadow = min(latest['open'], latest['close']) - latest['low']
    upper_shadow = latest['high'] - max(latest['open'], latest['close'])
    downtrend = chg20 < -3 or closes[-5] < latest_ma20 or latest_ma20 < latest_ma60

    swing_lows = local_extrema(lows[-35:], mode='low')
    swing_highs = local_extrema(highs[-35:], mode='high')
    support = min(lows[-20:])
    resistance = max(highs[-20:-1]) if len(highs) > 20 else max(highs[:-1])

    signals = []
    signal_notes = []
    score = 0
    risk_score = 0
    risk_flags = []

    bullish_engulfing = (
        prev['close'] < prev['open']
        and latest['close'] > latest['open']
        and latest_body_low <= prev_body_low
        and latest_body_high >= prev_body_high
    )
    if bullish_engulfing and downtrend:
        signals.append('看涨吞没')
        signal_notes.append('前阴后阳，阳线实体完整包住阴线实体')
        score += 16

    hammer = (
        downtrend
        and latest_body / latest_range < 0.35
        and lower_shadow > latest_body * 2.2
        and upper_shadow < latest_body * 1.1
    )
    if hammer:
        signals.append('锤头止跌')
        signal_notes.append('下跌段出现长下影小实体，存在止跌吸筹特征')
        score += 14

    double_support = False
    if len(swing_lows) >= 2:
        first_idx, first_low = swing_lows[-2]
        second_idx, second_low = swing_lows[-1]
        support_gap = abs(second_low - first_low) / max(first_low, 1e-6) * 100
        rebound = (closes[-1] - second_low) / max(second_low, 1e-6) * 100
        if second_idx - first_idx >= 4 and support_gap <= 2.5 and rebound >= 2:
            double_support = True
            support = (first_low + second_low) / 2
            signals.append('双底支撑')
            signal_notes.append('两次回踩同一支撑带后反弹，支撑有效')
            score += 13

    breakout = latest['close'] > resistance * 1.01 and prev['close'] <= resistance * 1.01
    if breakout:
        signals.append('突破阻力')
        signal_notes.append('价格放量突破近20日阻力位')
        score += 14

    higher_highs_lows = False
    if len(swing_highs) >= 2 and len(swing_lows) >= 2:
        higher_highs_lows = swing_highs[-1][1] > swing_highs[-2][1] and swing_lows[-1][1] > swing_lows[-2][1]
    if higher_highs_lows:
        signals.append('高低点抬升')
        signal_notes.append('阶段性高点与低点同步抬高，趋势向上')
        score += 10

    ma_up = latest_ma5 > latest_ma20 and ma5[-2] and ma20[-2] and latest_ma5 > ma5[-2] and latest_ma20 >= ma20[-2]
    if ma_up:
        signals.append('均线多头')
        signal_notes.append('5日均线站上20日均线且斜率向上')
        score += 12

    volume_burst = avg_vol20 > 0 and latest['volume'] > avg_vol20 * 1.45
    if volume_burst and (bullish_engulfing or hammer or breakout):
        signals.append('放量确认')
        signal_notes.append('看涨信号出现时成交量显著放大')
        score += 11

    volume_sync = chg5 > 1.0 and avg_vol20 > 0 and avg_vol5 >= avg_vol20 * 1.03
    if volume_sync:
        signals.append('价量齐升')
        signal_notes.append('价格上涨且量能同步放大，趋势延续概率较高')
        score += 9
    elif chg5 > 1.0 and avg_vol20 > 0 and avg_vol5 < avg_vol20 * 0.9:
        risk_flags.append('短线上涨但量能萎缩')
        risk_score += 18

    near_support = support > 0 and 0 <= (latest['close'] - support) / support * 100 <= 4.0
    if near_support and latest['close'] >= latest_ma20 * 0.96:
        signals.append('支撑企稳')
        signal_notes.append('股价在支撑位附近止跌企稳')
        score += 8

    rsi_rebound = rsi[-2] is not None and rsi[-1] is not None and rsi[-2] < 32 and rsi[-1] > rsi[-2]
    if rsi_rebound:
        signals.append('RSI反弹')
        signal_notes.append('RSI自低位回升，超卖修复开始')
        score += 8
    if rsi[-1] is not None and rsi[-1] >= 72:
        risk_flags.append('RSI进入偏高区')
        risk_score += 15

    macd_cross = dif[-2] <= dea[-2] and dif[-1] > dea[-1]
    if macd_cross or (hist[-2] <= 0 < hist[-1]):
        signals.append('MACD金叉')
        signal_notes.append('MACD由弱转强，短线动能改善')
        score += 10

    sector_bonus = evaluate_sector_context(stock, market_ctx)
    if sector_bonus['score'] > 0:
        signals.append('板块共振')
        signal_notes.append(sector_bonus['note'])
        score += sector_bonus['score']
    if sector_bonus['risk']:
        risk_flags.append(sector_bonus['risk'])
        risk_score += 8

    market_pct = market_ctx.get('marketPct', 0.0)
    if market_pct > 0.6 and stock.get('pct', 0.0) > market_pct:
        signals.append('强市领涨')
        signal_notes.append('市场整体偏强时个股表现优于大盘')
        score += 7
    elif market_pct < -0.5:
        risk_flags.append('大盘环境偏弱')
        risk_score += 8

    if latest['close'] > latest_ma20 * 1.12:
        risk_flags.append('股价偏离20日均线较大')
        risk_score += 10
    if breakout and not volume_burst:
        risk_flags.append('突破量能不足')
        risk_score += 10
    if volatility > 0.045:
        risk_flags.append('波动率偏高')
        risk_score += 8
    if avg_amt20 < 8e7:
        risk_flags.append('流动性一般')
        risk_score += 7

    if stock.get('latest', 0.0) < 2 or stock.get('amount', 0.0) < 1.2e8 or stock.get('turnover', 0.0) < 0.6:
        return None

    match_count = len(signals)
    if match_count < 4:
        return None

    final_score = score - risk_score * 0.35
    confidence = max(55, min(96, int(round(final_score))))
    if confidence < 60:
        return None

    if risk_score >= 35:
        risk_level = '高'
    elif risk_score >= 18:
        risk_level = '中'
    else:
        risk_level = '低'

    entry_hint = '沿5日线附近分批观察'
    if breakout and volume_burst:
        entry_hint = '放量突破后等待回踩不破阻力再分批关注'
    elif near_support or double_support:
        entry_hint = '支撑位附近企稳时可分批关注'
    elif bullish_engulfing or hammer:
        entry_hint = '等待次日继续放量确认再考虑跟进'

    reason_parts = signal_notes[:4]
    if not reason_parts:
        reason_parts = ['技术结构改善，短线具备继续走强基础']

    return {
        'code': stock['code'],
        'name': stock['name'],
        'sector': stock.get('industry') or '其他',
        'score': _round(final_score, 1),
        'confidence': confidence,
        'latestPrice': _round(latest['close'], 2),
        'latestPct': _round(stock.get('pct', latest.get('pct', 0.0)), 2),
        'latestPctStr': _pct_str(stock.get('pct', latest.get('pct', 0.0))),
        'latestPctClass': _pct_class(stock.get('pct', latest.get('pct', 0.0))),
        'support': _round(support, 2),
        'resistance': _round(resistance, 2),
        'rsi': _round(rsi[-1], 1) if rsi[-1] is not None else None,
        'macdDiff': _round(dif[-1], 4),
        'macdSignal': _round(dea[-1], 4),
        'turnover': _round(stock.get('turnover', latest.get('turnover', 0.0)), 2),
        'marketCap': _round(stock.get('marketCap', 0.0) / 1e8, 1),
        'signals': signals,
        'signalText': ' / '.join(signals[:5]),
        'reason': '；'.join(reason_parts),
        'entryHint': entry_hint,
        'riskLevel': risk_level,
        'riskFlags': risk_flags[:4],
        'riskText': '；'.join(risk_flags[:3]) if risk_flags else '量价关系与趋势结构相对健康',
        'matchCount': match_count,
        'volumeRatio': _round(avg_vol5 / avg_vol20, 2) if avg_vol20 else None,
        'fiveDayChange': _round(chg5, 2),
        'twentyDayChange': _round(chg20, 2),
        'drawdown20': _round(drawdown20, 2),
        'volatility': _round(volatility * 100, 2),
        'lastDate': latest['date'],
    }


def normalize_text(text):
    return str(text or '').replace(' ', '').lower()


def evaluate_sector_context(stock, market_ctx):
    industry = normalize_text(stock.get('industry', ''))
    events = market_ctx.get('events', [])
    heatmap = market_ctx.get('heatmap', [])
    sector_flows = market_ctx.get('sectorFlows', [])

    score = 0
    note_parts = []
    risk = ''

    for item in sector_flows:
        sector_name = normalize_text(item.get('name', ''))
        if sector_name and (sector_name in industry or industry in sector_name):
            if item.get('pct', 0.0) > 1 and item.get('mainNet', 0.0) > 0:
                score += 6
                note_parts.append(f"{item.get('name', '')}板块资金净流入明显")
            elif item.get('pct', 0.0) < -1 and item.get('mainNet', 0.0) < 0:
                risk = f"{item.get('name', '')}板块资金面偏弱"
            break

    for item in heatmap[:20]:
        tag = normalize_text(item.get('tag', ''))
        if tag and (tag in industry or industry in tag):
            temperature = _safe_float(item.get('temperature'), 0.0)
            trend = normalize_text(item.get('trend', ''))
            if temperature >= 60 or 'up' in trend or '升' in trend:
                score += 3
                note_parts.append(f"{item.get('tag', '')}热度维持高位")
            break

    event_hits = []
    for item in events[:25]:
        text = normalize_text(f"{item.get('title', '')}{item.get('reason', '')}{item.get('summary', '')}")
        if not text:
            continue
        if stock['name'].lower() in text or (industry and industry[:4] and industry[:4] in text):
            event_hits.append(item)
    if event_hits:
        score += 3
        note_parts.append('存在行业利好或事件催化')

    note = '；'.join(note_parts) if note_parts else '行业热度中性'
    return {'score': score, 'note': note, 'risk': risk}


def build_market_summary(indices, sector_flows, heatmap, events):
    market_pct = 0.0
    if indices:
        market_pct = sum(item.get('pct', 0.0) for item in indices) / len(indices)

    top_sector = ''
    if sector_flows:
        ranked = sorted(sector_flows, key=lambda item: (item.get('mainNet', 0.0), item.get('pct', 0.0)), reverse=True)
        if ranked:
            first = ranked[0]
            top_sector = f"{first.get('name', '')}板块资金净流入居前"

    hot_note = ''
    if heatmap:
        hottest = max(heatmap, key=lambda item: _safe_float(item.get('temperature'), 0.0))
        hot_note = f"热度最高的是{hottest.get('tag', '')}"
    elif events:
        hot_note = '近期热点事件仍在持续发酵'

    direction = '偏强' if market_pct > 0.5 else '震荡' if market_pct > -0.5 else '偏弱'
    summary = f"当前A股整体{direction}，指数均值{market_pct:+.2f}%"
    extras = '；'.join(part for part in [top_sector, hot_note] if part)
    if extras:
        summary = f'{summary}；{extras}'
    return summary, market_pct


def run_stock_screen(max_workers=20):
    print(f'[stock_screen] {datetime.now().strftime("%Y-%m-%d %H:%M:%S")} 开始执行A股形态筛选...')

    universe = fetch_a_share_universe()
    print(f'[stock_screen] 股票池数量: {len(universe)}')

    indices = fetch_market_snapshot()
    sector_flows = fetch_sector_flows()
    events, heatmap = load_hot_events()
    market_summary, market_pct = build_market_summary(indices, sector_flows, heatmap, events)
    market_ctx = {
        'sectorFlows': sector_flows,
        'events': events,
        'heatmap': heatmap,
        'marketPct': market_pct,
    }

    picks = []
    processed = 0
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        future_map = {executor.submit(fetch_stock_kline, stock): stock for stock in universe}
        for future in as_completed(future_map):
            stock = future_map[future]
            processed += 1
            if processed % 200 == 0:
                print(f'[stock_screen] 已处理 {processed}/{len(universe)}')
            try:
                rows = future.result()
                result = analyze_structure(stock, rows, market_ctx)
                if result:
                    picks.append(result)
            except urllib.error.HTTPError:
                continue
            except Exception as exc:
                print(f"[stock_screen] {stock['code']} {stock['name']} 失败: {exc}")

    picks.sort(key=lambda item: (item['score'], item['confidence'], item['matchCount']), reverse=True)
    top_picks = picks[:5]

    result = {
        'marketSummary': market_summary,
        'strategyNote': '优先关注放量突破、支撑确认、均线多头同时出现的个股；若量价背离或大盘转弱，需降低预期。',
        'picks': top_picks,
        'qualifiedCount': len(picks),
        'scannedCount': len(universe),
    }
    payload = {
        'date': datetime.now().strftime('%Y-%m-%d'),
        'timestamp': datetime.now().isoformat(),
        'triggerTime': 'daily',
        'result': result,
    }

    os.makedirs(DATA_DIR, exist_ok=True)
    with open(SCREEN_FILE, 'w', encoding='utf-8') as handle:
        json.dump(payload, handle, ensure_ascii=False, indent=2)

    print(f"[stock_screen] ✅ 完成，命中 {len(picks)} 只，已输出前 {len(top_picks)} 只")
    return payload


def load_stock_screen_cache():
    if not os.path.exists(SCREEN_FILE):
        return None
    try:
        with open(SCREEN_FILE, 'r', encoding='utf-8') as handle:
            return json.load(handle)
    except Exception:
        return None


if __name__ == '__main__':
    run_stock_screen()