#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
A股全市场短线强势股扫描器 V3
功能：
1. 遍历当天A股全部股票日K线
2. 技术面打分：趋势、形态、量能、RSI、MACD
3. 行业板块强度过滤
4. 输出前5只候选股
5. 输出"人话建议"
6. 自动给出：关注买点 / 止损位 / 第一目标位 / 盈亏比

服务端集成：
- run_stock_screen()   → 执行扫描并保存 JSON 到 data/stock_screen.json
- load_stock_screen_cache() → 读取缓存结果
"""

import json
import math
import os
import time
import warnings
from datetime import datetime, timedelta

import akshare as ak
import numpy as np
import pandas as pd
import pandas_ta as ta

warnings.filterwarnings("ignore")

