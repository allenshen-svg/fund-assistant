<view class="container">

  <!-- Debug: 错误信息面板 -->
  <view wx:if="{{debugError}}" style="background:#ff4444;color:#fff;padding:20rpx;font-size:24rpx;word-break:break-all;">
    <text>ERROR: {{debugError}}</text>
  </view>

  <!-- 数据新鲜度告警 -->
  <view wx:if="{{dataStaleLevel === 'warn'}}" class="stale-bar stale-warn">
    <text>⚠️ {{dataStaleMsg}}</text>
  </view>
  <view wx:if="{{dataStaleLevel === 'error'}}" class="stale-bar stale-error">
    <text>🔴 {{dataStaleMsg}}</text>
  </view>

  <!-- ====== Header ====== -->
  <view class="card header-card">
    <view class="row">
      <view class="header-left">
        <text class="header-title">📊 基金决策助手</text>
        <view class="header-meta">
          <view class="status-dot {{marketDot}}"></view>
          <text class="sub">{{marketStatus}}</text>
          <text class="sub" style="margin-left:12rpx;">{{currentTime}}</text>
        </view>
      </view>
      <text class="chip {{sourceLabel === '远程数据' ? 'blue' : 'gray'}}">{{sourceLabel}}</text>
    </view>
  </view>

  <!-- ====== 指数行情 ====== -->
  <view class="idx-grid">
    <view class="idx-item" wx:for="{{indices}}" wx:key="code">
      <text class="idx-name">{{item.name}}</text>
      <text class="idx-price">{{item.price}}</text>
      <text class="idx-pct pct-{{item.pctClass}}">{{item.pctStr}}</text>
    </view>
    <view wx:if="{{indices.length === 0}}" class="idx-item" style="width:100%;">
      <text class="sub">行情加载中...</text>
    </view>
  </view>

  <view class="feature-grid">
    <view class="feature-card" bindtap="goSentiment">
      <text class="feature-icon">🧭</text>
      <text class="feature-title">舆情分析</text>
      <text class="feature-desc">事件、热点和实时异动</text>
    </view>
    <view class="feature-card" bindtap="goHoldings">
      <text class="feature-icon">💼</text>
      <text class="feature-title">持仓管理</text>
      <text class="feature-desc">查看持仓与 AI 行动建议</text>
    </view>
    <view class="feature-card" bindtap="goSimulate">
      <text class="feature-icon">🧪</text>
      <text class="feature-title">模拟仓</text>
      <text class="feature-desc">模拟买卖与收益复盘</text>
    </view>
    <view class="feature-card feature-card-stock" bindtap="goStockScreen">
      <text class="feature-icon">🎯</text>
      <text class="feature-title">自动选股</text>
      <text class="feature-desc">进入即后台运行，完成后展示结果</text>
    </view>
  </view>

  <!-- ====== 大宗商品实时行情 ====== -->
  <view class="card" wx:if="{{commodities.length > 0}}">
    <view class="card-header">
      <text class="title">📦 大宗商品</text>
      <text class="sub">{{commodities[0].closed ? '上次收盘' : '期货主力合约'}}</text>
    </view>
    <view class="comm-grid">
      <view class="comm-item {{item.anomaly ? 'comm-anomaly' : ''}}" wx:for="{{commodities}}" wx:key="code">
        <view class="comm-icon-row">
          <text class="comm-icon">{{item.icon}}</text>
          <text class="comm-name">{{item.short}}</text>
        </view>
        <text class="comm-price">{{item.price}}</text>
        <text class="comm-pct pct-{{item.pctClass}}">{{item.pctStr}}</text>
        <text class="comm-anomaly-tag" wx:if="{{item.anomaly}}">异动</text>
      </view>
    </view>
  </view>

  <!-- ====== 实时热点异动 ====== -->
  <view class="card" wx:if="{{hotBreaking.length > 0}}">
    <view class="card-header">
      <text class="title">🔥 实时热点 · 异动</text>
      <view class="row" style="align-items:center;">
        <text class="chip red">{{hotBreaking.length}}条</text>
        <text class="rt-live-dot">●</text>
        <text class="sub" wx:if="{{rtCountdown}}" style="margin-left:4rpx;font-size:20rpx;color:#10b981;">{{rtCountdown}}</text>
        <text class="sub" wx:if="{{rtUpdatedAt}}" style="margin-left:8rpx;font-size:20rpx;">⚡{{rtUpdatedAt}}</text>
      </view>
    </view>
    <view class="breaking-groups">
      <view class="breaking-group" wx:for="{{breakingGroups}}" wx:key="cat">
        <view class="breaking-group-header {{item.cat}}" bindtap="toggleBreakingGroup" data-cat="{{item.cat}}">
          <view class="breaking-group-left">
            <text class="breaking-group-icon">{{item.icon}}</text>
            <text class="breaking-group-label">{{item.label}}</text>
            <text class="breaking-group-count">{{item.count}}条</text>
          </view>
          <text class="breaking-group-arrow {{expandedCats[item.cat] ? 'expanded' : ''}}">▶</text>
        </view>
        <view class="breaking-list" wx:if="{{expandedCats[item.cat]}}">
          <view class="breaking-item {{sub.isGeo ? 'geo' : sub.category === 'monetary' ? 'monetary' : sub.category === 'technology' ? 'tech' : sub.category === 'cls_flash' ? 'cls-flash' : sub.category === 'market' ? 'market' : 'comm'}}" wx:for="{{item.items}}" wx:for-item="sub" wx:key="id">
            <view class="breaking-top">
              <text class="breaking-source" wx:if="{{sub.source}}">{{sub.source}}</text>
              <text class="rt-badge" wx:if="{{sub.isRealtime && sub.category !== 'cls_flash'}}">LIVE</text>
              <text class="rt-badge sentiment" wx:if="{{sub.fromSentiment}}">舆情</text>
              <text class="breaking-time" wx:if="{{sub.timeLabel}}">{{sub.timeLabel}}</text>
            </view>
            <text class="breaking-title">{{sub.title}}</text>
            <view class="breaking-impact-row" wx:if="{{sub.category !== 'cls_flash'}}">
              <text class="chip sm {{sub.impactClass}}">影响 {{sub.impact >= 0 ? '+' : ''}}{{sub.impact}}</text>
            </view>
            <text class="breaking-reason" wx:if="{{sub.reason}}">{{sub.reason}}</text>
            <text class="breaking-analyst" wx:if="{{sub.analystView}}">🧭 分析师观点：{{sub.analystView}}</text>
            <view class="breaking-bottom" wx:if="{{sub.sectorsPos || sub.sectorsNeg}}">
              <text class="breaking-pos" wx:if="{{sub.sectorsPos}}">▲ {{sub.sectorsPos}}</text>
              <text class="breaking-neg" wx:if="{{sub.sectorsNeg}}">▼ {{sub.sectorsNeg}}</text>
            </view>
            <text class="breaking-advice" wx:if="{{sub.advice}}">💡 {{sub.advice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 持仓概览 ====== -->
  <view class="card">
    <view class="card-header">
      <text class="title">💼 持仓概览</text>
      <view class="row">
        <text class="total-pct pct-{{totalPctClass}}">{{totalPct}}</text>
        <text class="sub" style="margin-left:12rpx;">均值</text>
      </view>
    </view>

    <view wx:if="{{holdings.length === 0 && !loading}}" class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="sub">暂无持仓</text>
      <button class="btn sm" style="margin-top:20rpx;" bindtap="goHoldings">去添加</button>
    </view>

    <view class="holdings-grid" wx:if="{{holdings.length > 0}}">
      <view class="holding-card" wx:for="{{holdings}}" wx:key="code">
        <view class="row">
          <text class="h-name">{{item.name}}</text>
          <text class="h-pct pct-{{item.pctClass}}">{{item.pctStr}}</text>
        </view>
        <view class="row" style="margin-top:6rpx;">
          <text class="sub">{{item.code}} · {{item.type}}</text>
          <text class="sub" wx:if="{{item.estimate}}">估值 {{item.estimate}}</text>
          <view class="h-ai-btn {{singleAILoading === item.code ? 'h-ai-loading' : ''}}" catchtap="triggerSingleFundAI" data-code="{{item.code}}" data-name="{{item.name}}" data-type="{{item.type}}">
            <text>{{singleAILoading === item.code ? '⏳' : '🤖'}} {{singleAILoading === item.code ? '分析中' : 'AI分析'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 实盘行动指南 ====== -->
  <view class="card">
    <view class="card-header ag-guide-header">
      <view class="ag-title-group">
        <text class="title">🎯 实盘行动指南</text>
        <text class="chip {{overview.score >= 60 ? 'up' : overview.score <= 40 ? 'down' : 'gray'}}">
          {{overview.label}} · {{overview.score}}分
        </text>
      </view>
      <view class="ai-trigger-btn {{aiLoading ? 'ai-btn-loading' : ''}} {{aiResult && !aiLoading ? 'ai-btn-done' : ''}}" bindtap="triggerAI">
        <view class="ai-btn-pulse" wx:if="{{aiLoading}}"></view>
        <text class="ai-btn-icon">{{aiLoading ? '⏳' : '🤖'}}</text>
        <text class="ai-btn-label">{{aiLoading ? '分析中' : 'AI分析'}}</text>
      </view>
    </view>
    <view class="overview-bar">
      <view class="ob-item red"><text class="ob-num">{{overview.buy}}</text><text class="ob-label">加仓</text></view>
      <view class="ob-item green"><text class="ob-num">{{overview.sell}}</text><text class="ob-label">减仓</text></view>
      <view class="ob-item gray"><text class="ob-num">{{overview.hold}}</text><text class="ob-label">持有</text></view>
    </view>

    <view class="divider"></view>

    <view wx:if="{{plans.length === 0 && !loading}}" class="sub" style="text-align:center;padding:20rpx 0;">
      添加持仓后可看研判建议
    </view>

    <!-- ===== 每只基金的丰富分析卡片 ===== -->
    <view class="ag-card action-{{item.action}}" wx:for="{{plans}}" wx:key="code" data-idx="{{index}}" bindtap="togglePlan">

      <!-- 顶部: 名称 + 代码 + 涨跌 + 行动标签 -->
      <view class="ag-top">
        <view class="ag-top-left">
          <text class="ag-name">{{item.name}}</text>
          <view class="row" style="margin-top:4rpx;">
            <text class="sub">{{item.code}} · {{item.type}}</text>
            <text class="ag-today-pct pct-{{item.pctClass}}" wx:if="{{item.pctStr !== '待开盘'}}"> {{item.pctStr}}</text>
          </view>
        </view>
        <view class="ag-top-right">
          <text class="ag-priority">#{{item.priority}}</text>
          <text class="ag-urgency ag-urgency-{{item.urgencyClass}}">{{item.urgency}}</text>
          <text class="ag-action-badge action-{{item.action}}">{{item.actionLabel}}</text>
        </view>
      </view>

      <!-- 投票条: 因子投票 + 共识 + 波段建议 -->
      <view class="ag-vote-strip">
        <view class="ag-vote-chip" wx:for="{{item.factors}}" wx:for-item="f" wx:key="name"
              wx:if="{{index < 4}}">
          <text class="ag-vote-label">{{f.name}}</text>
          <text class="ag-vote-val vote-{{f.dir}}">{{f.val}}</text>
        </view>
        <text class="ag-consensus-chip consensus-{{item.consensus === '共识看多' || item.consensus === '偏多' ? 'buy' : item.consensus === '共识看空' || item.consensus === '偏空' ? 'sell' : 'hold'}}">
          {{item.consensus}}
        </text>
        <text class="ag-swing-chip" wx:if="{{item.swingAdvice !== '—'}}">{{item.swingAdvice}}</text>
      </view>

      <!-- 趋势 + 波段 + MA + 资金流 -->
      <view class="ag-trend-row" wx:if="{{item.hasTrend}}">
        <text class="ag-trend-tag" style="color:{{item.dirColor}}">{{item.dirIcon}} {{item.dirText}}</text>
        <text class="ag-trend-tag" style="color:{{item.swingColor}}">{{item.swingIcon}} {{item.swingText}}</text>
        <text class="ag-trend-tag ag-ma-{{item.maStatus === '多头排列' ? 'bull' : item.maStatus === '空头排列' ? 'bear' : 'mix'}}">{{item.maStatus}}</text>
        <text class="ag-trend-tag ag-flow-{{item.sectorFlowDir}}" wx:if="{{item.sectorFlowText}}">💰{{item.sectorFlowText}}</text>
      </view>

      <!-- 关键指标条 -->
      <view class="ag-metrics" wx:if="{{item.hasTrend}}">
        <text class="ag-metric">RSI {{item.rsi}}</text>
        <text class="ag-metric">5日 {{item.chg5d}}</text>
        <text class="ag-metric">20日 {{item.chg20d}}</text>
        <text class="ag-metric" wx:if="{{item.showDrawdown}}">距高点 {{item.drawdown}}</text>
        <text class="ag-metric" wx:if="{{item.showRebound}}">从低点 +{{item.rebound}}</text>
        <text class="ag-metric">波动 {{item.volatility}}</text>
      </view>

      <!-- 风险标签 -->
      <view class="ag-risk-row">
        <text class="ag-risk-badge risk-{{item.riskLevel === '高风险' ? 'high' : item.riskLevel === '中风险' ? 'mid' : 'low'}}">
          ⚠️ {{item.riskLevel}} · {{item.riskScore}}分
        </text>
        <text class="sub">🔥 {{item.tag}} · {{item.temperature}}°</text>
        <text class="ag-crowding" wx:if="{{item.crowding}}">{{item.crowding}}</text>
      </view>

      <!-- ===== 展开详情: 白话研判 ===== -->
      <view class="ag-detail" wx:if="{{item.expanded}}">
        <view class="ag-detail-divider"></view>

        <!-- 一句话诊断 -->
        <view class="ag-tldr">
          <text class="ag-tldr-icon">💡</text>
          <text class="ag-tldr-text">{{item.advisor.tldr}}</text>
        </view>

        <!-- 四维体检 -->
        <view class="ag-checkup">
          <view class="ag-checkup-item">
            <text class="ag-ck-label">估值</text>
            <text class="ag-ck-val" style="color:{{item.advisor.valuation.color}}">{{item.advisor.valuation.label}}</text>
          </view>
          <view class="ag-checkup-item">
            <text class="ag-ck-label">趋势</text>
            <text class="ag-ck-val" style="color:{{item.advisor.trendLabel.color}}">{{item.advisor.trendLabel.label}}</text>
          </view>
          <view class="ag-checkup-item">
            <text class="ag-ck-label">风向</text>
            <text class="ag-ck-val">{{item.advisor.windDir}}</text>
          </view>
          <view class="ag-checkup-item">
            <text class="ag-ck-label">隐患</text>
            <text class="ag-ck-val" style="font-size:20rpx;">{{item.advisor.biggestRisk}}</text>
          </view>
        </view>

        <!-- 原始数据 -->
        <view class="ag-raw-data">
          <text class="ag-raw-item">今日 {{item.advisor.rawData.todayPct}}</text>
          <text class="ag-raw-item">20日 {{item.advisor.rawData.chg20d}}</text>
          <text class="ag-raw-item">回撤 {{item.advisor.rawData.drawdown}}</text>
          <text class="ag-raw-item">波动 {{item.advisor.rawData.volatility}}</text>
          <text class="ag-raw-item">RSI {{item.advisor.rawData.rsi}}</text>
          <text class="ag-raw-item">热度 {{item.advisor.rawData.heat}}</text>
        </view>

        <!-- 行动方案 -->
        <view class="ag-action-plan">
          <view class="ag-plan-row">
            <text class="ag-plan-label">📋 操作</text>
            <text class="ag-plan-val">{{item.advisor.operation}}</text>
          </view>
          <view class="ag-plan-row">
            <text class="ag-plan-label">🎯 战术</text>
            <text class="ag-plan-val">{{item.advisor.tactics}}</text>
          </view>
          <view class="ag-plan-row">
            <text class="ag-plan-label">🛡️ 止损</text>
            <text class="ag-plan-val">{{item.advisor.stopLoss}}</text>
          </view>
        </view>

        <!-- AI 加减仓方案 -->
        <view wx:if="{{item.aiPlan}}" class="ai-fund-plan">
          <view class="ai-fund-plan-header">
            <text class="ai-fund-plan-title">{{item.aiPlan.autoFilled ? '🤖 算法补充方案' : '🤖 AI 加减仓方案'}}</text>
            <text class="ai-fund-plan-badge ai-fp-{{item.aiPlan.finalAction}}">{{item.aiPlan.finalLabel}}</text>
          </view>
          <view wx:if="{{item.aiPlan.autoFilled}}" class="ai-fp-auto-note">
            <text class="sub">⚠️ AI未覆盖此基金，已用本地算法自动补充</text>
          </view>

          <view class="ai-fp-compare">
            <view class="ai-fp-col">
              <text class="ai-fp-label">📊 算法建议</text>
              <text class="ai-fp-val">{{item.aiPlan.algoLabel}}</text>
            </view>
            <view class="ai-fp-vs">
              <text>VS</text>
            </view>
            <view class="ai-fp-col">
              <text class="ai-fp-label">🤖 AI建议</text>
              <text class="ai-fp-val">{{item.aiPlan.aiLabel}}</text>
            </view>
          </view>

          <view class="ai-fp-detail">
            <view class="ai-fp-row">
              <text class="ai-fp-key">📐 仓位调整</text>
              <text class="ai-fp-value">{{item.aiPlan.posAdj}}</text>
            </view>
            <view class="ai-fp-row">
              <text class="ai-fp-key">💡 综合依据</text>
              <text class="ai-fp-value">{{item.aiPlan.reason}}</text>
            </view>
            <view class="ai-fp-row">
              <text class="ai-fp-key">🎯 AI置信度</text>
              <text class="ai-fp-value">{{item.aiPlan.aiConfidence}}</text>
            </view>
            <view class="ai-fp-row" wx:if="{{item.aiPlan.aiReason}}">
              <text class="ai-fp-key">📝 AI理由</text>
              <text class="ai-fp-value">{{item.aiPlan.aiReason}}</text>
            </view>
            <view class="ai-fp-row">
              <text class="ai-fp-key">⏰ 紧急程度</text>
              <text class="ai-fp-value">{{item.aiPlan.aiUrgency}}</text>
            </view>
          </view>
        </view>
        <view wx:elif="{{!item.aiPlan}}" class="ai-fund-plan-empty">
          <text class="sub">🤖 点击顶部「AI分析」按钮获取加减仓方案</text>
        </view>

        <!-- 雷达图 (用 CSS bars 代替 SVG) -->
        <view class="ag-radar">
          <view class="ag-radar-item">
            <text class="ag-radar-label">估值力</text>
            <view class="ag-radar-bar"><view class="ag-radar-fill" style="width:{{item.advisor.radar.valuation}}%;"></view></view>
            <text class="ag-radar-num">{{item.advisor.radar.valuation}}</text>
          </view>
          <view class="ag-radar-item">
            <text class="ag-radar-label">爆发力</text>
            <view class="ag-radar-bar"><view class="ag-radar-fill" style="width:{{item.advisor.radar.momentum}}%;"></view></view>
            <text class="ag-radar-num">{{item.advisor.radar.momentum}}</text>
          </view>
          <view class="ag-radar-item">
            <text class="ag-radar-label">顺风度</text>
            <view class="ag-radar-bar"><view class="ag-radar-fill" style="width:{{item.advisor.radar.macro}}%;"></view></view>
            <text class="ag-radar-num">{{item.advisor.radar.macro}}</text>
          </view>
          <view class="ag-radar-item">
            <text class="ag-radar-label">防御力</text>
            <view class="ag-radar-bar"><view class="ag-radar-fill" style="width:{{item.advisor.radar.defense}}%;"></view></view>
            <text class="ag-radar-num">{{item.advisor.radar.defense}}</text>
          </view>
          <view class="ag-radar-item">
            <text class="ag-radar-label">情绪度</text>
            <view class="ag-radar-bar"><view class="ag-radar-fill" style="width:{{item.advisor.radar.sentiment}}%;"></view></view>
            <text class="ag-radar-num">{{item.advisor.radar.sentiment}}</text>
          </view>
        </view>

        <text class="ag-expand-hint">▲ 收起详情</text>
      </view>

      <!-- 未展开时的展开提示 -->
      <text class="ag-expand-hint" wx:if="{{!item.expanded}}">▼ 展开详细分析</text>
    </view>
  </view>

  <!-- ====== 模型组合 ====== -->
  <view class="card">
    <view class="card-header" bindtap="toggleModel">
      <text class="title">📐 波段组合</text>
      <text class="sub">{{showModel ? '收起 ▲' : '展开 ▼'}}</text>
    </view>
    <view wx:if="{{showModel}}">
      <view class="model-section">
        <text class="model-section-title">核心仓 60%</text>
        <view class="model-fund" wx:for="{{modelCore}}" wx:key="code">
          <view class="row">
            <text class="model-name">{{item.name}}</text>
            <text class="model-weight">{{item.weight}}%</text>
          </view>
          <text class="sub">{{item.code}} · {{item.type}}</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="model-section">
        <text class="model-section-title">卫星仓 40%</text>
        <view class="model-fund" wx:for="{{modelSat}}" wx:key="code">
          <view class="row">
            <text class="model-name">{{item.name}}</text>
            <text class="model-weight">{{item.weight}}%</text>
          </view>
          <text class="sub">{{item.code}} · {{item.type}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 板块热力 ====== -->
  <view class="card" wx:if="{{heatmap.length > 0}}">
    <view class="card-header">
      <text class="title">🌡️ 板块热力</text>
    </view>
    <view class="heat-grid">
      <view class="heat-chip heat-{{item.trend}}" wx:for="{{heatmap}}" wx:key="tag"
            style="opacity:{{0.55 + item.temperature / 200}};">
        <text class="heat-tag">{{item.tag}}</text>
        <view class="heat-bottom">
          <text class="heat-pct" wx:if="{{item.realPct != null}}">{{item.realPct > 0 ? '+' : ''}}{{item.realPct}}%</text>
          <text class="heat-pct" wx:else>{{item.temperature}}°</text>
          <text class="heat-trend-arrow" wx:if="{{item.trend === 'up'}}">▲</text>
          <text class="heat-trend-arrow" wx:if="{{item.trend === 'down'}}">▼</text>
          <text class="heat-trend-arrow" wx:if="{{item.trend === 'stable'}}">—</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 选基金/股票 ====== -->
  <view class="card fp-card">
    <view class="card-header">
      <view class="fp-title-group">
        <text class="title">🏆 选基金/股票</text>
        <text class="sub" wx:if="{{fundPickTime}}">{{fundPickTime}}</text>
      </view>
      <view class="fp-trigger-btn {{fundPickLoading ? 'fp-btn-loading' : ''}} {{fundPickResult && !fundPickLoading ? 'fp-btn-done' : ''}}" bindtap="triggerFundPick">
        <view class="ai-btn-pulse" wx:if="{{fundPickLoading}}"></view>
        <text class="ai-btn-icon">{{fundPickLoading ? '⏳' : '🧠'}}</text>
        <text class="ai-btn-label">{{fundPickLoading ? '选股中' : 'AI选股'}}</text>
      </view>
    </view>

    <!-- Loading state -->
    <view wx:if="{{fundPickLoading && !fundPickResult}}" class="fp-loading">
      <view class="ai-loading-dots">
        <view class="ai-ld"></view>
        <view class="ai-ld ai-ld2"></view>
        <view class="ai-ld ai-ld3"></view>
      </view>
      <text class="fp-loading-text">{{fundPickProgress || '正在筛选增长板块...'}}</text>
    </view>

    <!-- 无结果提示 -->
    <view wx:if="{{!fundPickResult && !fundPickLoading}}" class="fp-empty">
      <text class="fp-empty-icon">📊</text>
      <text class="fp-empty-text">点击右上角「AI选股」，基金经理视角精选标的</text>
    </view>

    <!-- 结果展示 -->
    <view wx:if="{{fundPickResult}}">
      <!-- 板块轮动总览 -->
      <view class="fp-overview" wx:if="{{fundPickResult.sectorOverview}}">
        <text class="fp-overview-text">{{fundPickResult.sectorOverview}}</text>
      </view>

      <!-- ===== 基金推荐（5只）===== -->
      <view class="fp-section" wx:if="{{fundPickResult.fundPicks && fundPickResult.fundPicks.length > 0}}">
        <view class="fp-section-header fp-section-fund">
          <text class="fp-section-icon">💰</text>
          <text class="fp-section-title">基金推荐</text>
          <text class="fp-section-count">{{fundPickResult.fundPicks.length}}只</text>
        </view>
        <view class="fp-picks">
          <view class="fp-pick {{item.showDetail ? 'fp-pick-open' : ''}}" wx:for="{{fundPickResult.fundPicks}}" wx:key="code" data-idx="{{index}}" data-list="fundPicks" bindtap="togglePickDetail">
            <view class="fp-pick-top">
              <view class="fp-pick-left">
                <view class="fp-pick-type-badge fp-type-fund">基</view>
                <view class="fp-pick-info">
                  <text class="fp-pick-name">{{item.name}}</text>
                  <text class="fp-pick-code">{{item.code}} · {{item.sector}} {{item.sectorPct || ''}}</text>
                </view>
              </view>
              <view class="fp-pick-right">
                <text class="fp-pick-rating fp-rating-{{item.rating}}">
                  {{item.rating === 'strong_buy' ? '🔥 强推' : item.rating === 'buy' ? '👍 推荐' : '📈 吸纳'}}
                </text>
                <text class="fp-pick-confidence">{{item.confidence || 75}}%</text>
              </view>
            </view>
            <view class="fp-pick-detail" wx:if="{{item.showDetail}}">
              <view class="fp-detail-section">
                <text class="fp-detail-label">📊 看好板块原因</text>
                <text class="fp-detail-text">{{item.whyThisSector}}</text>
              </view>
              <view class="fp-detail-section">
                <text class="fp-detail-label">🎯 选择理由</text>
                <text class="fp-detail-text">{{item.whyThisPick}}</text>
              </view>
              <view class="fp-detail-section">
                <text class="fp-detail-label">📈 3个月支撑分析</text>
                <text class="fp-detail-text">{{item.supportAnalysis}}</text>
              </view>
              <view class="fp-detail-section">
                <text class="fp-detail-label">💡 买入策略</text>
                <text class="fp-detail-text fp-strategy-text">{{item.strategy}}</text>
              </view>
              <view class="fp-detail-row">
                <view class="fp-detail-item">
                  <text class="fp-detail-label">🎯 预期收益</text>
                  <text class="fp-detail-val fp-val-up">{{item.targetReturn || '--'}}</text>
                </view>
                <view class="fp-detail-item">
                  <text class="fp-detail-label">⚠️ 风险</text>
                  <text class="fp-detail-val fp-val-risk">{{item.riskPoints || '--'}}</text>
                </view>
              </view>
              <view class="fp-add-btn" catchtap="addPickToHoldings" data-code="{{item.code}}" data-name="{{item.name}}" data-type="{{item.sector}}">
                <text>+ 加入持仓</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- ===== 股票推荐（5只）===== -->
      <view class="fp-section" wx:if="{{fundPickResult.stockPicks && fundPickResult.stockPicks.length > 0}}">
        <view class="fp-section-header fp-section-stock">
          <text class="fp-section-icon">📈</text>
          <text class="fp-section-title">股票推荐</text>
          <text class="fp-section-count">{{fundPickResult.stockPicks.length}}只</text>
        </view>
        <view class="fp-picks">
          <view class="fp-pick {{item.showDetail ? 'fp-pick-open' : ''}}" wx:for="{{fundPickResult.stockPicks}}" wx:key="code" data-idx="{{index}}" data-list="stockPicks" bindtap="togglePickDetail">
            <view class="fp-pick-top">
              <view class="fp-pick-left">
                <view class="fp-pick-type-badge fp-type-stock">股</view>
                <view class="fp-pick-info">
                  <text class="fp-pick-name">{{item.name}}</text>
                  <text class="fp-pick-code">{{item.code}} · {{item.sector}} {{item.sectorPct || ''}}</text>
                </view>
              </view>
              <view class="fp-pick-right">
                <text class="fp-pick-rating fp-rating-{{item.rating}}">
                  {{item.rating === 'strong_buy' ? '🔥 强推' : item.rating === 'buy' ? '👍 推荐' : '📈 吸纳'}}
                </text>
                <text class="fp-pick-confidence">{{item.confidence || 75}}%</text>
              </view>
            </view>
            <view class="fp-pick-detail" wx:if="{{item.showDetail}}">
              <view class="fp-detail-section">
                <text class="fp-detail-label">📊 看好板块原因</text>
                <text class="fp-detail-text">{{item.whyThisSector}}</text>
              </view>
              <view class="fp-detail-section">
                <text class="fp-detail-label">🎯 选择理由</text>
                <text class="fp-detail-text">{{item.whyThisPick}}</text>
              </view>
              <view class="fp-detail-section">
                <text class="fp-detail-label">📈 3个月支撑分析</text>
                <text class="fp-detail-text">{{item.supportAnalysis}}</text>
              </view>
              <view class="fp-detail-section">
                <text class="fp-detail-label">💡 买入策略</text>
                <text class="fp-detail-text fp-strategy-text">{{item.strategy}}</text>
              </view>
              <view class="fp-detail-row">
                <view class="fp-detail-item">
                  <text class="fp-detail-label">🎯 预期收益</text>
                  <text class="fp-detail-val fp-val-up">{{item.targetReturn || '--'}}</text>
                </view>
                <view class="fp-detail-item">
                  <text class="fp-detail-label">⚠️ 风险</text>
                  <text class="fp-detail-val fp-val-risk">{{item.riskPoints || '--'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 配置建议 -->
      <view class="fp-advice" wx:if="{{fundPickResult.allocationAdvice}}">
        <view class="fp-advice-header">
          <text class="fp-advice-icon">💰</text>
          <text class="fp-advice-label">资金配置建议</text>
        </view>
        <text class="fp-advice-text">{{fundPickResult.allocationAdvice}}</text>
      </view>

      <!-- 风险提示 -->
      <view class="fp-risk" wx:if="{{fundPickResult.marketRisk}}">
        <text class="fp-risk-text">⚠️ {{fundPickResult.marketRisk}}</text>
      </view>
    </view>
  </view>

  <!-- ====== AI 智能分析 ====== -->
  <view class="card" wx:if="{{aiResult || aiLoading}}">
    <view class="card-header sec-toggle" bindtap="toggleAI">
      <text class="title">🤖 AI 智能分析</text>
      <view class="ai-section-meta">
        <text class="sub" wx:if="{{aiTime}}">{{aiTime}}</text>
        <text class="toggle-arrow">{{showAI ? '▲' : '▼'}}</text>
      </view>
    </view>
    <!-- AI 加载中占位 -->
    <view wx:if="{{aiLoading && !aiResult}}" class="ai-loading-inline">
      <view class="ai-loading-dots">
        <view class="ai-ld"></view>
        <view class="ai-ld ai-ld2"></view>
        <view class="ai-ld ai-ld3"></view>
      </view>
      <text class="sub" style="margin-top:12rpx;">{{aiProgress || 'AI 正在深度分析，请稍候...'}}</text>
    </view>
    <view wx:if="{{!showAI && aiResult}}" class="ai-summary-hint">
      <text class="sub">✅ 已有分析结果，点击展开查看详情</text>
    </view>
    <view wx:if="{{showAI && aiResult}}">
      <view class="ai-result">

        <!-- 市场温度计 -->
        <view class="ai-temp-bar">
          <view class="ai-temp-track">
            <view class="ai-temp-fill" style="width:{{aiMarketTemp}}%;"></view>
            <view class="ai-temp-dot" style="left:{{aiMarketTemp}}%;"></view>
          </view>
          <view class="ai-temp-labels">
            <text class="ai-temp-label">❄️ 恐慌</text>
            <text class="ai-temp-label">⚖️ 中性</text>
            <text class="ai-temp-label">🔥 贪婪</text>
          </view>
        </view>

        <!-- 市场总览 -->
        <view class="ai-market-bar">
          <text class="ai-market-text">{{aiResult.marketSummary}}</text>
          <text class="ai-risk-tag ai-risk-{{aiResult.riskClass}}">{{aiResult.riskLevel}}</text>
        </view>

        <!-- 未来1个月展望 -->
        <view wx:if="{{aiResult.marketOutlook}}" class="ai-outlook-card">
          <text class="ai-outlook-title">🔮 未来1个月展望</text>
          <text class="ai-outlook-text">{{aiResult.marketOutlook}}</text>
        </view>

        <!-- 板块轮动建议 -->
        <view wx:if="{{aiResult.sectorRotation}}" class="ai-sector-card">
          <text class="ai-sector-title">🔄 板块轮动</text>
          <text class="ai-sector-text">{{aiResult.sectorRotation}}</text>
        </view>

        <!-- 持仓基金AI分析信号列表 -->
        <view class="ai-signals-header">
          <text class="ai-signals-title">📊 持仓AI分析</text>
        </view>
        <view class="ai-signal" wx:for="{{aiResult.signals}}" wx:key="code" data-idx="{{index}}" bindtap="toggleSignalDetail">
          <view class="ai-sig-top">
            <view class="ai-sig-left">
              <text class="ai-sig-name">{{item.name}}</text>
              <text class="sub">{{item.code}} · 置信度 {{item.confidenceStr}}</text>
            </view>
            <view class="ai-sig-badge ai-sig-{{item.actionClass}}">
              <text>{{item.actionLabel}}</text>
            </view>
          </view>
          <text class="ai-sig-reason">{{item.reason}}</text>
          <!-- 展开详细分析 -->
          <view wx:if="{{item.showDetail}}" class="ai-sig-detail">
            <view class="ai-sig-analysis">
              <text class="ai-sig-analysis-text">{{item.analysis}}</text>
            </view>
            <view class="ai-sig-extra">
              <view class="ai-sig-extra-row" wx:if="{{item.targetReturn}}">
                <text class="ai-sig-extra-key">📈 预期收益</text>
                <text class="ai-sig-extra-val">{{item.targetReturn}}</text>
              </view>
              <view class="ai-sig-extra-row" wx:if="{{item.riskWarning}}">
                <text class="ai-sig-extra-key">⚠️ 风险提示</text>
                <text class="ai-sig-extra-val">{{item.riskWarning}}</text>
              </view>
              <view class="ai-sig-extra-row" wx:if="{{item.bestTiming}}">
                <text class="ai-sig-extra-key">⏰ 最佳时机</text>
                <text class="ai-sig-extra-val">{{item.bestTiming}}</text>
              </view>
              <view class="ai-sig-meta">
                <text class="sub" wx:if="{{item.urgency}}">紧急度：{{item.urgency}}</text>
              </view>
            </view>
          </view>
          <text class="ag-expand-hint">{{item.showDetail ? '▲ 收起' : '▼ 展开详细分析'}}</text>
        </view>

        <!-- 总体建议 -->
        <view wx:if="{{aiResult.overallAdvice}}" class="ai-overall">
          <text class="ai-overall-label">📝 总体建议</text>
          <text class="ai-overall-text">{{aiResult.overallAdvice}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 更新时间 ====== -->
  <view class="footer-info">
    <text class="sub">数据更新：{{updatedAt}}</text>
  </view>

  <!-- AI 分析浮动进度条 -->
  <view class="ai-float-bar" wx:if="{{aiLoading}}">
    <view class="ai-float-shimmer"></view>
    <view class="ai-float-content">
      <text class="ai-float-icon">🤖</text>
      <text class="ai-float-text">{{aiProgress || 'AI 深度分析中，可继续浏览'}}</text>
    </view>
  </view>

  <!-- 单基金 AI 分析浮动进度条 -->
  <view class="ai-float-bar" wx:if="{{singleAILoading}}">
    <view class="ai-float-shimmer"></view>
    <view class="ai-float-content">
      <text class="ai-float-icon">🤖</text>
      <text class="ai-float-text">{{singleAIProgress || '正在分析单只基金...'}}</text>
    </view>
  </view>

  <!-- 单基金 AI 分析结果弹窗 -->
  <view class="sfai-mask" wx:if="{{showSingleAI}}" bindtap="closeSingleAI"></view>
  <view class="sfai-popup" wx:if="{{showSingleAI}}">
    <!-- 顶部拖拽指示条 -->
    <view class="sfai-drag-bar"><view class="sfai-drag-line"></view></view>

    <!-- 标题栏 -->
    <view class="sfai-header">
      <view class="sfai-title-row">
        <text class="sfai-title">{{singleAIResult.fundName}}</text>
        <text class="sfai-code">{{singleAIResult.fundCode}}</text>
      </view>
      <view class="sfai-close" bindtap="closeSingleAI">✕</view>
    </view>

    <scroll-view scroll-y class="sfai-body" enhanced show-scrollbar="{{false}}">
      <!-- 走势总结卡片 -->
      <view class="sfai-card sfai-trend-card">
        <view class="sfai-card-icon">📈</view>
        <view class="sfai-card-content">
          <text class="sfai-card-label">走势总结</text>
          <text class="sfai-text">{{singleAIResult.trendSummary}}</text>
        </view>
      </view>

      <!-- 板块资金流 -->
      <view class="sfai-card sfai-flow-card" wx:if="{{singleAIResult._sectorFlow}}">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">💰</text>
          <text class="sfai-section-label">板块资金流向</text>
        </view>
        <view class="sfai-flow-data">
          <view class="sfai-flow-sector">
            <text class="sfai-flow-name">{{singleAIResult._sectorFlow.name}}</text>
            <view class="sfai-flow-badge sfai-flow-{{singleAIResult._sectorFlow.flowDir}}">
              <text class="sfai-flow-arrow">{{singleAIResult._sectorFlow.flowDir === 'in' ? '↑' : '↓'}}</text>
              <text class="sfai-flow-amount">主力 {{singleAIResult._sectorFlow.flowText}}</text>
            </view>
          </view>
          <view class="sfai-flow-detail">
            <view class="sfai-flow-item">
              <text class="sfai-flow-item-label">板块涨幅</text>
              <text class="sfai-flow-item-val {{singleAIResult._sectorFlow.pct >= 0 ? 'sfai-val-up' : 'sfai-val-down'}}">{{singleAIResult._sectorFlow.pct >= 0 ? '+' : ''}}{{singleAIResult._sectorFlow.pct}}%</text>
            </view>
            <view class="sfai-flow-item">
              <text class="sfai-flow-item-label">主力净占比</text>
              <text class="sfai-flow-item-val">{{singleAIResult._sectorFlow.mainPct}}%</text>
            </view>
          </view>
        </view>
        <view class="sfai-divider" wx:if="{{singleAIResult.sectorAnalysis}}"></view>
        <text class="sfai-text sfai-analysis-text" wx:if="{{singleAIResult.sectorAnalysis}}">{{singleAIResult.sectorAnalysis}}</text>
      </view>

      <!-- 无板块资金流时仅显示AI板块分析 -->
      <view class="sfai-card" wx:if="{{!singleAIResult._sectorFlow && singleAIResult.sectorAnalysis}}">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">💰</text>
          <text class="sfai-section-label">板块资金分析</text>
        </view>
        <text class="sfai-text">{{singleAIResult.sectorAnalysis}}</text>
      </view>

      <!-- 走势原因 -->
      <view class="sfai-card">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">🔍</text>
          <text class="sfai-section-label">走势原因分析</text>
        </view>
        <text class="sfai-text">{{singleAIResult.whyTrend}}</text>
      </view>

      <!-- 深度因果分析 -->
      <view class="sfai-card sfai-deep-card" wx:if="{{singleAIResult.deepAnalysis}}">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">🧠</text>
          <text class="sfai-section-label">深度因果链分析</text>
        </view>
        <text class="sfai-text sfai-deep-text">{{singleAIResult.deepAnalysis}}</text>
      </view>

      <!-- 关键事件影响 -->
      <view class="sfai-card" wx:if="{{singleAIResult.keyEvents}}">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">🔥</text>
          <text class="sfai-section-label">关键事件影响</text>
        </view>
        <text class="sfai-text">{{singleAIResult.keyEvents}}</text>
      </view>

      <!-- 技术面 -->
      <view class="sfai-card">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">📊</text>
          <text class="sfai-section-label">技术面分析</text>
        </view>
        <text class="sfai-text">{{singleAIResult.technicalView}}</text>
      </view>

      <!-- 操作建议（突出卡片）— 含一周走势 + 今日建议 + 时机 -->
      <view class="sfai-card sfai-action-card action-bg-{{singleAIResult.action}}">
        <view class="sfai-action-header">
          <view class="sfai-action-badge action-{{singleAIResult.action}}">{{singleAIResult.action === 'buy' ? '买入' : singleAIResult.action === 'add' ? '加仓' : singleAIResult.action === 'sell' ? '卖出' : singleAIResult.action === 'reduce' ? '减仓' : '持有'}}</view>
          <text class="sfai-section-label">今日操作建议</text>
        </view>
        <view class="sfai-week-trend" wx:if="{{singleAIResult.weekTrend}}">
          <text class="sfai-week-trend-label">📅 一周走势</text>
          <text class="sfai-week-trend-text">{{singleAIResult.weekTrend}}</text>
        </view>
        <text class="sfai-text">{{singleAIResult.todayAdvice || singleAIResult.actionAdvice}}</text>
        <view class="sfai-timing" wx:if="{{singleAIResult.timing}}">
          <text class="sfai-timing-icon">⏰</text>
          <text class="sfai-timing-text">{{singleAIResult.timing}}</text>
        </view>
      </view>

      <!-- 风险提示 -->
      <view class="sfai-card sfai-risk-card" wx:if="{{singleAIResult.riskWarning}}">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">⚠️</text>
          <text class="sfai-section-label">风险提示</text>
        </view>
        <text class="sfai-text sfai-risk-text">{{singleAIResult.riskWarning}}</text>
      </view>

      <!-- 未来展望 -->
      <view class="sfai-card" wx:if="{{singleAIResult.outlook}}">
        <view class="sfai-section-title">
          <text class="sfai-section-icon">🔮</text>
          <text class="sfai-section-label">未来展望</text>
        </view>
        <text class="sfai-text">{{singleAIResult.outlook}}</text>
      </view>

      <!-- 底部信息 -->
      <view class="sfai-footer">
        <text class="sfai-footer-text">🤖 由 AI 生成 · {{singleAITime}}</text>
        <text class="sfai-footer-tip">仅供参考，不构成投资建议</text>
      </view>
    </scroll-view>
  </view>

</view>
