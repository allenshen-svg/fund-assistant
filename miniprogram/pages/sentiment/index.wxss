/* ====== 总览信号卡 ====== */
.summary-card { padding-bottom: 20rpx; }

/* ====== AI 自动分析横幅 ====== */
.ai-analyzing-banner {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(139,92,246,0.08));
  border: 1rpx solid rgba(99,102,241,0.2);
}
.ai-pulse {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #6366f1;
  animation: aiPulse 1.2s ease-in-out infinite;
}
@keyframes aiPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}
.ai-analyzing-text {
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 600;
}

/* ====== 精简刷新按钮 ====== */
.refresh-mini {
  margin-left: auto;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(99,102,241,0.10);
  border: 1rpx solid rgba(99,102,241,0.20);
}
.refresh-mini-text {
  font-size: 22rpx;
  color: #6366f1;
  font-weight: 600;
}
.refresh-mini-text.refreshing {
  color: var(--text-sub);
  margin-left: auto;
  font-size: 20rpx;
}
.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.signal-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
}
.signal-box.buy    { background: rgba(239,68,68,0.12); }
.signal-box.hold   { background: rgba(234,179,8,0.12); }
.signal-box.defensive { background: rgba(249,115,22,0.12); }
.signal-box.sell   { background: rgba(220,38,38,0.12); }
.signal-box.wait   { background: rgba(148,163,184,0.12); }
.signal-icon { font-size: 40rpx; }
.signal-text { font-size: 28rpx; font-weight: 700; color: var(--text); }

.temp-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 14rpx;
}
.temp-box.overheat { background: rgba(239,68,68,0.15); }
.temp-box.hot      { background: rgba(249,115,22,0.12); }
.temp-box.warm     { background: rgba(234,179,8,0.10); }
.temp-box.neutral  { background: rgba(148,163,184,0.10); }
.temp-box.cold     { background: rgba(59,130,246,0.12); }
.temp-val { font-size: 36rpx; font-weight: 800; color: var(--text-strong); }
.temp-label { font-size: 22rpx; color: var(--text-body); }

.radar-summary {
  font-size: 26rpx;
  color: #f59e0b;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.hot-assets {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}
.asset-pill {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fbbf24;
  background: rgba(251,191,36,0.10);
  border: 1rpx solid rgba(251,191,36,0.25);
  border-radius: 999rpx;
}

/* 指标条 */
.gauge-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.gauge-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.gauge-label { font-size: 22rpx; color: var(--text-sub); width: 60rpx; }
.gauge-bar-bg {
  flex: 1;
  height: 14rpx;
  background: var(--elevated-4);
  border-radius: 8rpx;
  overflow: hidden;
}
.gauge-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}
.gauge-bar.fomo   { background: linear-gradient(90deg, #f59e0b, #ef4444); }
.gauge-bar.panic  { background: linear-gradient(90deg, #22c55e, #3b82f6); }
.gauge-bar.diverge { background: linear-gradient(90deg, #a855f7, #6366f1); }
.gauge-val { font-size: 22rpx; color: var(--text); width: 50rpx; text-align: right; }

.summary-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

/* ====== 隔夜美股 ====== */
.us-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}
.us-item {
  display: flex;
  flex-direction: column;
  padding: 14rpx;
  border-radius: 12rpx;
  background: var(--elevated);
  border: 1rpx solid var(--border-subtle);
}
.us-name { font-size: 24rpx; font-weight: 700; color: var(--text); }
.us-price { font-size: 22rpx; color: var(--text-body); margin-top: 4rpx; }
.us-pct { font-size: 24rpx; font-weight: 700; margin-top: 4rpx; }
.us-amp { font-size: 20rpx; color: var(--text-faint); margin-top: 2rpx; }

/* ====== 大宗商品近1月走势 ====== */
.commodity-tabs {
  white-space: nowrap;
  margin-bottom: 14rpx;
}
.commodity-tab {
  display: inline-block;
  padding: 8rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(148,163,184,0.10);
  color: var(--text-faint);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.commodity-tab.active {
  background: rgba(148,163,184,0.06);
  font-weight: 700;
}

.commodity-trend-canvas {
  display: block;
  border-radius: 12rpx;
  background: rgba(148,163,184,0.04);
}

.commodity-sel-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
  padding: 0 4rpx;
}
.commodity-dot-lg {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.commodity-sel-name {
  font-size: 24rpx;
  color: var(--text);
  font-weight: 600;
  flex: 1;
}
.commodity-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}
.commodity-name {
  font-size: 22rpx;
  color: var(--text);
  font-weight: 600;
}
.commodity-pct {
  font-size: 26rpx;
  font-weight: 700;
}

/* ====== 板块深度影响分析 ====== */

/* ====== 板块深度影响分析 ====== */
.deep-card {
  padding: 20rpx;
  margin-bottom: 18rpx;
  border-radius: 14rpx;
  background: rgba(239,68,68,0.04);
  border: 1rpx solid rgba(239,68,68,0.12);
  border-left: 6rpx solid rgba(239,68,68,0.5);
}
.deep-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.deep-pin {
  font-size: 28rpx;
  flex-shrink: 0;
}
.deep-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.5;
  flex: 1;
}
.deep-content-wrap {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(239,68,68,0.10);
}
.deep-rich-content {
  display: block;
  font-size: 24rpx;
  color: var(--text-body);
  line-height: 1.7;
}

/* 深度分析 - 关联商品涨跌 */
.deep-commodity-row {
  margin-bottom: 12rpx;
}
.deep-commodity-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 6rpx;
}
.deep-commodity-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(148,163,184,0.08);
  border: 1rpx solid rgba(148,163,184,0.15);
}
.deep-commodity-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.deep-commodity-name {
  font-size: 22rpx;
  color: var(--text);
  font-weight: 600;
}
.deep-commodity-pct {
  font-size: 22rpx;
  font-weight: 700;
}

/* 深度分析卡片样式 */
.deep-section .card-header {
  border-bottom: 1rpx solid rgba(239,68,68,0.10);
  padding-bottom: 12rpx;
  margin-bottom: 16rpx;
}

/* ====== 板块投资策略 ====== */
.sector-actions {
  margin-bottom: 18rpx;
}
.sector-action-item {
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid var(--text-faint);
  background: var(--elevated);
}
.sector-action-item.bullish {
  border-left-color: #ef4444;
  background: rgba(239,68,68,0.05);
}
.sector-action-item.bearish {
  border-left-color: #22c55e;
  background: rgba(34,197,94,0.05);
}
.sector-action-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.sector-action-icon {
  font-size: 26rpx;
}
.sector-action-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
}
.sector-action-text {
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.6;
}

/* ====== 操作指南 ====== */
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 18rpx;
}
.action-item {
  padding: 14rpx;
  border-radius: 12rpx;
  border-left: 5rpx solid var(--text-faint);
  background: var(--elevated);
}
.action-item.bullish {
  border-left-color: #ef4444;
  background: rgba(239,68,68,0.05);
}
.action-item.bearish {
  border-left-color: #22c55e;
  background: rgba(34,197,94,0.05);
}
.action-item.neutral {
  border-left-color: var(--text-faint);
}
.action-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 6rpx;
}
.action-advice {
  font-size: 22rpx;
  color: var(--text-body);
  line-height: 1.6;
  display: block;
}

.action-summary {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.summary-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 12rpx;
}
.summary-line.bullish  { background: rgba(239,68,68,0.12); }
.summary-line.bearish  { background: rgba(34,197,94,0.12); }
.summary-line.tactical { background: rgba(59,130,246,0.12); }
.summary-icon { font-size: 32rpx; flex-shrink: 0; }
.summary-content { flex: 1; }
.summary-head { font-size: 24rpx; font-weight: 700; color: var(--text); display: block; }
.summary-body { font-size: 22rpx; color: var(--text-body); line-height: 1.6; display: block; margin-top: 4rpx; }

/* ====== 折叠控制 ====== */
.toggle-icon {
  font-size: 22rpx;
  color: var(--text-faint);
  margin-left: auto;
  padding-left: 12rpx;
}

/* ====== Footer ====== */
.footer {
  text-align: center;
  padding: 30rpx 20rpx;
}

/* ====== 事件条目 ====== */
.evt-item {
  border-top: 1rpx solid var(--border-subtle);
  padding: 18rpx 0;
}

.evt-item:first-child {
  border-top: none;
}

.evt-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  max-width: 520rpx;
  flex: 1;
}

.evt-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.evt-sectors {
  margin-top: 6rpx;
}
