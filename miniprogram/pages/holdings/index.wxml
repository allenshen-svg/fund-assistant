<view class="container">

  <!-- ====== 当前持仓 ====== -->
  <view class="card">
    <view class="card-header">
      <text class="title">💼 当前持仓</text>
      <text class="sub">共 {{list.length}} 只</text>
    </view>

    <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="sub">暂无持仓，请添加基金</text>
    </view>

    <view class="h-item" wx:for="{{list}}" wx:key="code">
      <view class="h-main">
        <view class="h-left">
          <text class="h-name">{{item.name}}</text>
          <text class="sub">{{item.code}} · {{item.type}}</text>
        </view>
        <view class="h-right">
          <text class="h-pct pct-{{item.pctClass}}">{{item.pctStr}}</text>
          <text class="sub" wx:if="{{item.estimate}}">估值 {{item.estimate}}</text>
        </view>
      </view>
      <view class="h-actions">
        <text class="del-btn" data-code="{{item.code}}" data-name="{{item.name}}" bindtap="removeHolding">删除</text>
      </view>
    </view>
  </view>

  <!-- ====== 波段组合（持仓基金） ====== -->
  <view class="card">
    <view class="card-header sec-toggle" data-key="secSwing" bindtap="toggleSection">
      <text class="title">📊 波段组合</text>
      <text class="toggle-arrow">{{secSwing ? '▲' : '▼'}}</text>
    </view>
    <view class="sec-sub-header" wx:if="{{!secSwing}}">
      <text class="sub">基于持仓基金的波段信号分析</text>
    </view>
    <view wx:if="{{secSwing}}">
      <view wx:if="{{swingLoading}}" class="loading-tip">
        <text>加载趋势数据中...</text>
      </view>
      <view wx:elif="{{swingItems.length === 0}}" class="empty-state">
        <text class="sub">暂无持仓</text>
      </view>
      <view wx:else>
        <view class="swing-card swing-{{item.swingClass}}" wx:for="{{swingItems}}" wx:key="code">
          <view class="swing-top">
            <view class="swing-left">
              <text class="swing-name">{{item.name}}</text>
              <text class="sub">{{item.code}} · {{item.type}}</text>
            </view>
            <view class="swing-badge swing-badge-{{item.swingClass}}">
              <text>{{item.swingSignal}}</text>
            </view>
          </view>
          <view wx:if="{{item.hasTrend}}" class="swing-detail">
            <view class="swing-grid">
              <view class="sg-item">
                <text class="sg-label">5日涨幅</text>
                <text class="sg-val {{item.chg5dClass}}">{{item.chg5d}}</text>
              </view>
              <view class="sg-item">
                <text class="sg-label">20日涨幅</text>
                <text class="sg-val {{item.chg20dClass}}">{{item.chg20d}}</text>
              </view>
              <view class="sg-item">
                <text class="sg-label">RSI</text>
                <text class="sg-val">{{item.rsi}}</text>
              </view>
              <view class="sg-item">
                <text class="sg-label">回撤</text>
                <text class="sg-val pct-down">{{item.drawdown}}</text>
              </view>
              <view class="sg-item">
                <text class="sg-label">反弹</text>
                <text class="sg-val pct-up">{{item.rebound}}</text>
              </view>
              <view class="sg-item">
                <text class="sg-label">均线</text>
                <text class="sg-val">{{item.maStatus}}</text>
              </view>
            </view>
            <view wx:if="{{item.swingAdvice}}" class="swing-advice">
              <text class="sub">💡 {{item.swingAdvice}}</text>
            </view>
          </view>
          <view wx:else class="swing-nodata">
            <text class="sub">数据不足，无法分析</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 今日操作建议 ====== -->
  <view class="card">
    <view class="card-header sec-toggle" data-key="secDaily" bindtap="toggleSection">
      <text class="title">🎯 今日操作建议</text>
      <text class="toggle-arrow">{{secDaily ? '▲' : '▼'}}</text>
    </view>
    <view class="sec-sub-header" wx:if="{{!secDaily}}">
      <text class="sub">基于近一周走势 + 市场局势，AI给出今日操作</text>
    </view>
    <view wx:if="{{secDaily}}">
      <!-- 操作按钮 -->
      <view class="wk-actions">
        <button class="btn small" bindtap="loadDailyAdvice" disabled="{{dailyLoading}}">
          🤖 {{dailyLoading ? 'AI分析中...' : '生成今日建议'}}
        </button>
        <text wx:if="{{dailyTime}}" class="sub wk-time">更新: {{dailyTime}}</text>
      </view>

      <!-- 分析结果 -->
      <view wx:if="{{dailyResult}}">
        <!-- 市场定调 -->
        <view class="wk-summary-card">
          <view class="wk-summary-top">
            <text class="wk-summary-text">{{dailyResult.marketBrief}}</text>
            <text class="wk-risk-badge wk-{{dailyResult.riskCls}}">{{dailyResult.riskIcon}} {{dailyResult.riskLevel}}</text>
          </view>
        </view>

        <!-- 每只基金的今日建议 -->
        <view class="wk-fund-card wk-fund-{{item.actionCls}}" wx:for="{{dailyResult.funds}}" wx:key="code">
          <view class="wk-fund-top">
            <view class="wk-fund-left">
              <text class="wk-fund-name">{{item.name}}</text>
              <text class="sub">{{item.code}} · 周{{item.weekChange}}</text>
            </view>
            <view class="wk-fund-right">
              <text class="wk-action-badge wk-action-{{item.actionCls}}">{{item.actionIcon}} {{item.actionLabel}}</text>
            </view>
          </view>
          <view class="wk-fund-body">
            <view class="wk-fund-row">
              <text class="wk-row-label">一周走势</text>
              <text class="sub">{{item.weekTrend}}</text>
            </view>
            <view class="wk-fund-row">
              <text class="wk-row-label">操作理由</text>
              <text class="wk-advice-text">{{item.reason}}</text>
            </view>
            <view class="wk-fund-row">
              <text class="wk-row-label">操作时机</text>
              <text class="wk-timing-text">⏰ {{item.timing}}</text>
            </view>
          </view>
          <view wx:if="{{item.confidence}}" class="wk-conf-bar">
            <view class="wk-conf-fill" style="width: {{item.confidence}}%;"></view>
            <text class="wk-conf-label">置信度 {{item.confidence}}%</text>
          </view>
        </view>
      </view>

      <!-- 无结果提示 -->
      <view wx:elif="{{!dailyLoading}}" class="empty-state">
        <text class="empty-icon">🎯</text>
        <text class="sub">点击"生成今日建议"开始AI分析</text>
      </view>
    </view>
  </view>

  <!-- ====== 预测追踪 ====== -->
  <view class="card">
    <view class="card-header sec-toggle" data-key="secPred" bindtap="toggleSection">
      <text class="title">🎯 预测追踪</text>
      <text class="toggle-arrow">{{secPred ? '▲' : '▼'}}</text>
    </view>
    <view class="sec-sub-header" wx:if="{{!secPred}}">
      <text class="sub">追踪每日投资建议的准确率</text>
    </view>
    <view wx:if="{{secPred}}">
      <!-- 操作按钮 -->
      <view class="pred-actions">
        <button class="btn small" bindtap="snapshotPrediction" disabled="{{predTodayDone}}">
          📸 {{predTodayDone ? '今日已快照' : '立即快照'}}
        </button>
        <button class="btn small ghost" bindtap="manualVerify">✅ 手动验证</button>
      </view>

      <!-- 统计概览 -->
      <view wx:if="{{predStats && predStats.totalDays > 0}}" class="pred-stats-card">
        <view class="pred-stats-row">
          <view class="ps-item">
            <text class="ps-val big">{{predStats.totalDays}}</text>
            <text class="ps-label">追踪天数</text>
          </view>
          <view class="ps-item">
            <text class="ps-val big pct-up">{{predStats.accuracy > 0 ? predStats.accuracy.toFixed(0) + '%' : '--'}}</text>
            <text class="ps-label">总准确率</text>
          </view>
          <view class="ps-item">
            <text class="ps-val">{{predStats.correctCount}}</text>
            <text class="ps-label">✅ 正确</text>
          </view>
          <view class="ps-item">
            <text class="ps-val">{{predStats.wrongCount}}</text>
            <text class="ps-label">❌ 错误</text>
          </view>
        </view>
        <!-- 准确率进度条 -->
        <view class="pred-bar-wrap">
          <view class="pred-bar">
            <view class="pred-bar-fill" style="width: {{predStats.accuracy}}%;"></view>
          </view>
          <text class="sub" style="margin-top:4rpx;">准确率 {{predStats.accuracy.toFixed(1)}}%</text>
        </view>
      </view>
      <view wx:elif="{{predStats && predStats.totalDays === 0}}" class="empty-state">
        <text class="empty-icon">🎯</text>
        <text class="sub">暂无追踪数据，点击"立即快照"开始追踪</text>
      </view>

      <!-- 最近验证详情 -->
      <view wx:if="{{predLatest}}" class="pred-latest">
        <view class="pred-latest-header">
          <text class="title">📋 最近验证 ({{predLatest.date}})</text>
          <text class="pred-acc-badge {{predLatest.accuracyClass}}">{{predLatest.accuracy}}</text>
        </view>
        <view class="pred-result-item" wx:for="{{predLatest.results}}" wx:key="name">
          <view class="pr-left">
            <text class="pr-icon">{{item.verdictIcon}}</text>
            <text class="pr-name">{{item.name}}</text>
          </view>
          <view class="pr-right">
            <text class="pr-pred">建议: {{item.predLabel}}</text>
            <text class="pr-actual {{item.nextPctClass}}">次日: {{item.nextPct}}</text>
          </view>
        </view>
      </view>

      <!-- 历史记录 -->
      <view wx:if="{{predHistory.length > 0}}" class="pred-history">
        <text class="sub-title">📅 历史快照</text>
        <view class="ph-item" wx:for="{{predHistory}}" wx:key="date">
          <view class="ph-left">
            <text class="ph-date">{{item.date}}</text>
            <text class="sub">{{item.timestamp}} · {{item.overallLabel}}</text>
          </view>
          <view class="ph-right">
            <text class="ph-acc {{item.verified ? 'verified' : 'pending'}}">{{item.accuracyStr}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 操作按钮 ====== -->
  <view class="action-btns">
    <button class="btn" bindtap="toggleAdd">➕ 添加基金</button>
  </view>

</view>

<!-- ====== 添加基金弹窗（浮层） ====== -->
<view class="modal-mask" wx:if="{{showAdd}}" bindtap="toggleAdd">
  <view class="modal-panel" catchtap="noop">
    <!-- 标题栏 -->
    <view class="modal-header">
      <text class="title">➕ 添加基金</text>
      <text class="modal-close" bindtap="toggleAdd">✕</text>
    </view>

    <!-- 搜索区域 -->
    <view class="search-row">
      <input class="input search-input" type="number" maxlength="6"
             placeholder="输入6位基金代码" value="{{code}}" focus="{{showAdd}}"
             placeholder-style="color: rgba(255,255,255,0.4);"
             bindinput="onCodeInput" bindconfirm="doSearchFund" />
      <button class="btn small search-btn" bindtap="doSearchFund"
              disabled="{{searching}}">{{searching ? '查询中...' : '🔍 查找'}}</button>
    </view>

    <!-- 搜索结果 -->
    <view wx:if="{{searchResult}}" class="search-result">
      <view class="sr-info">
        <text class="sr-name">{{searchResult.name}}</text>
        <text class="sub">{{searchResult.code}} · {{searchResult.type}}</text>
        <text wx:if="{{searchResult.pct !== null}}" class="sr-pct pct-{{searchResult.pct >= 0 ? 'up' : 'down'}}">
          今日估值: {{searchResult.pct >= 0 ? '+' : ''}}{{searchResult.pct}}%
        </text>
      </view>
      <button class="btn sr-add-btn" bindtap="addFromSearch">✅ 确认添加</button>
    </view>

    <!-- 搜索错误 -->
    <view wx:if="{{searchError}}" class="search-error">
      <text class="sub">{{searchError}}</text>
    </view>

    <!-- 手动输入（搜索未果时展开） -->
    <view wx:if="{{searchError || (!searchResult && code.length === 6)}}" class="manual-section">
      <view class="manual-divider">
        <text class="sub">── 或手动填写 ──</text>
      </view>
      <view class="form-item">
        <text class="label">基金名称</text>
        <input class="input" placeholder="例如 华安黄金ETF联接A" value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="form-item">
        <text class="label">基金类型</text>
        <picker mode="selector" range="{{typeOptions}}" value="{{typeIndex}}" bindchange="onTypeChange">
          <view class="input picker-val">{{typeOptions[typeIndex]}} ▾</view>
        </picker>
      </view>
      <button class="btn" style="margin-top:16rpx;" bindtap="addHolding">确认添加</button>
    </view>
  </view>
</view>
