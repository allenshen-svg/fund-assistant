<wxs src="../../utils/fmt.wxs" module="fmt" />
<view class="container">

  <!-- ====== 加载骨架屏 ====== -->
  <view class="card sim-overview-card" wx:if="{{loading}}">
    <view class="card-header">
      <text class="title">🏦 模拟仓</text>
      <text class="sub">加载中...</text>
    </view>
    <view class="sim-skeleton">
      <view class="skeleton-line skeleton-w60"></view>
      <view class="skeleton-line skeleton-w40"></view>
      <view class="skeleton-line skeleton-w80"></view>
    </view>
  </view>

  <!-- ====== 组合概览 ====== -->
  <view class="card sim-overview-card" wx:if="{{!loading}}">
    <view class="card-header">
      <text class="title">🏦 模拟仓</text>
      <text class="sub">自动执行</text>
    </view>

    <view class="sim-auto-banner" wx:if="{{remoteMode}}">
      <text class="sim-auto-title">服务端自动模拟仓</text>
      <text class="sim-auto-desc" wx:if="{{hasRemoteData && autoMeta}}">{{autoMeta.tradeSchedule}}；{{autoMeta.reviewSchedule}}</text>
      <text class="sim-auto-desc sim-auto-ai-tag" wx:if="{{autoMeta && autoMeta.aiStatus && autoMeta.aiStatus.last !== 'ok'}}">⚠️ AI分析状态: {{autoMeta.aiStatus.last === 'unknown' ? '待验证' : '当前使用规则引擎'}}</text>
      <text class="sim-auto-desc" wx:if="{{!hasRemoteData && syncError}}">{{syncError}}</text>
      <text class="sim-auto-desc" wx:if="{{portfolio.lastTradeSummary && portfolio.lastTradeSummary.date}}">
        最近执行：{{portfolio.lastTradeSummary.date}}，买入 {{portfolio.lastTradeSummary.buyCount || 0}} 笔，减仓 {{portfolio.lastTradeSummary.sellCount || 0}} 笔
      </text>
      <view class="sim-auto-config" wx:if="{{latestSizingLabel}}">
        <text class="sim-auto-config-chip">{{latestSizingLabel}}</text>
      </view>
      <text class="sim-auto-desc" wx:if="{{latestSizingNotes}}">最近买入仓位依据：{{latestSizingNotes}}</text>
      <text class="sim-auto-desc">页面仅展示程序自动交易结果，不提供手动加仓、减仓或手动触发入口。</text>
      <view class="sim-auto-config" wx:if="{{autoConfigSummary.length > 0}}">
        <text class="sim-auto-config-chip" wx:for="{{autoConfigSummary}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="sim-summary">
      <view class="sim-summary-main">
        <text class="sim-total-label">总资产</text>
        <text class="sim-total-value" wx:if="{{hasRemoteData}}">¥{{fmt.fmtNum(totalValue)}}</text>
        <text class="sim-total-value" wx:else>--</text>
        <text class="sim-return pct-{{totalReturnClass}}" wx:if="{{hasRemoteData}}">{{totalReturn}}</text>
        <text class="sim-return" wx:else>等待服务端连接</text>
      </view>
      <view class="sim-summary-row">
        <view class="sim-summary-item">
          <text class="sim-summary-label">可用现金</text>
          <text class="sim-summary-val" wx:if="{{hasRemoteData}}">¥{{fmt.fmtNum(cash)}}</text>
          <text class="sim-summary-val" wx:else>--</text>
        </view>
        <view class="sim-summary-item">
          <text class="sim-summary-label">初始资金</text>
          <text class="sim-summary-val" wx:if="{{hasRemoteData}}">¥{{fmt.fmtNum(totalCash)}}</text>
          <text class="sim-summary-val" wx:else>--</text>
        </view>
        <view class="sim-summary-item">
          <text class="sim-summary-label">持仓数</text>
          <text class="sim-summary-val" wx:if="{{hasRemoteData}}">{{positionList.length}}</text>
          <text class="sim-summary-val" wx:else>--</text>
        </view>
      </view>

      <!-- 结算状态 -->
      <view class="sim-settle-row" wx:if="{{positionList.length > 0}}">
        <view class="sim-settle-info">
          <text class="sim-settle-label">{{remoteMode ? '最近结算' : '今日盈亏'}}</text>
          <text class="sim-settle-pnl pct-{{dailyPnlClass}}" wx:if="{{dailyPnl}}">{{fmt.fmtNum(dailyPnl)}} ({{dailyPct}})</text>
          <text class="sim-settle-pnl" wx:else>待结算</text>
        </view>
        <view class="sim-settle-right">
          <text class="sim-settle-date sub" wx:if="{{settleDate}}">{{settleDate}} 已结算</text>
          <text class="sim-settle-btn" bindtap="manualSettle">{{settling ? '刷新中...' : '🔄 刷新'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{remoteMode}}">
    <view class="card-header">
      <text class="title">🧭 本周收益归因</text>
      <text class="sub" wx:if="{{weeklyAttribution && weeklyAttribution.returnPct}}">{{weeklyAttribution.returnPct}}</text>
    </view>
    <view wx:if="{{weeklyAttribution}}">
      <view class="sim-attrib-grid">
        <view class="sim-attrib-item">
          <text class="sim-attrib-label">买入次数</text>
          <text class="sim-attrib-value">{{weeklyAttribution.buyCount || 0}}</text>
        </view>
        <view class="sim-attrib-item">
          <text class="sim-attrib-label">减仓次数</text>
          <text class="sim-attrib-value">{{weeklyAttribution.sellCount || 0}}</text>
        </view>
        <view class="sim-attrib-item">
          <text class="sim-attrib-label">买入金额</text>
          <text class="sim-attrib-value">¥{{fmt.fmtNum(weeklyAttribution.buyAmount || 0)}}</text>
        </view>
        <view class="sim-attrib-item">
          <text class="sim-attrib-label">卖出金额</text>
          <text class="sim-attrib-value">¥{{fmt.fmtNum(weeklyAttribution.sellAmount || 0)}}</text>
        </view>
      </view>
      <view class="sim-attrib-section" wx:if="{{weeklyAttribution.summary}}">
        <text class="sim-attrib-title">归因总结</text>
        <text class="sim-attrib-text">{{weeklyAttribution.summary}}</text>
      </view>
      <view class="sim-attrib-section" wx:if="{{weeklyAttribution.analysis}}">
        <text class="sim-attrib-title">盈亏原因</text>
        <text class="sim-attrib-text">{{weeklyAttribution.analysis}}</text>
      </view>
      <view class="sim-factor-grid" wx:if="{{weeklyAttribution.factorBreakdown && weeklyAttribution.factorBreakdown.length > 0}}">
        <view class="sim-factor-item" wx:for="{{weeklyAttribution.factorBreakdown}}" wx:key="key">
          <view class="sim-factor-top">
            <text class="sim-factor-label">{{item.label}}</text>
            <text class="sim-factor-score">{{item.score}}分</text>
          </view>
          <view class="sim-factor-bar">
            <view class="sim-factor-fill" style="width: {{item.score}}%;"></view>
          </view>
          <text class="sim-factor-summary">{{item.summary}}</text>
        </view>
      </view>
      <view class="sim-attrib-pair" wx:if="{{weeklyAttribution.bestTrade || weeklyAttribution.worstTrade}}">
        <text class="sim-attrib-pair-item" wx:if="{{weeklyAttribution.bestTrade}}">最佳: {{weeklyAttribution.bestTrade}}</text>
        <text class="sim-attrib-pair-item" wx:if="{{weeklyAttribution.worstTrade}}">最差: {{weeklyAttribution.worstTrade}}</text>
      </view>
      <view class="sim-attrib-section" wx:if="{{weeklyAttribution.lessons && weeklyAttribution.lessons.length > 0}}">
        <text class="sim-attrib-title">后续改进</text>
        <text class="sim-attrib-text" wx:for="{{weeklyAttribution.lessons}}" wx:key="*this">• {{item}}</text>
      </view>
      <view class="sim-attrib-section" wx:if="{{weeklyAttribution.nextWeekStrategy}}">
        <text class="sim-attrib-title">下周策略</text>
        <text class="sim-attrib-text">{{weeklyAttribution.nextWeekStrategy}}</text>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="sub">暂无周度收益归因，等本周五 15:10 自动生成</text>
    </view>
  </view>

  <view class="card" wx:if="{{remoteMode}}">
    <view class="card-header">
      <text class="title">🗂️ 本周自动交易明细</text>
      <text class="sub">{{weeklyTradeDetails.length}} 笔</text>
    </view>
    <view wx:if="{{weeklyTradeDetails.length > 0}}">
      <view class="sim-week-trade-item" wx:for="{{weeklyTradeDetails}}" wx:key="id">
        <view class="sim-week-trade-top">
          <text class="sim-log-action sim-log-{{item.action}}">{{item.action === 'buy' ? '买入' : '卖出'}}</text>
          <text class="sim-week-trade-name">{{item.name}}</text>
          <text class="sim-week-trade-amount {{item.action === 'buy' ? 'pct-down' : 'pct-up'}}">{{item.action === 'buy' ? '-' : '+'}}¥{{fmt.fmtNum(item.amount)}}</text>
        </view>
        <view class="sim-week-trade-meta">
          <text class="sub">{{item.date}}</text>
          <text class="sub">{{item.code}}</text>
          <text class="sub">{{item.sector}}</text>
          <text class="sub">{{item.aiSource}}</text>
        </view>
        <view class="sim-week-trade-tags" wx:if="{{item.sizingLabel}}">
          <text class="sim-trade-chip sim-trade-chip-accent">{{item.sizingLabel}}</text>
        </view>
        <text class="sim-week-trade-reason" wx:if="{{item.reason}}">{{item.reason}}</text>
        <text class="sim-week-trade-reason sub" wx:if="{{item.sizingNotesText}}">仓位信号: {{item.sizingNotesText}}</text>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="sub">本周暂无自动交易记录</text>
    </view>
  </view>

  <!-- ====== 当前持仓 ====== -->
  <view class="card" wx:if="{{positionList.length > 0}}">
    <view class="card-header">
      <text class="title">💼 模拟持仓</text>
      <text class="sub" wx:if="{{refreshing}}">刷新中...</text>
      <text class="sub" wx:else>共 {{positionList.length}} 只</text>
    </view>

    <view class="sim-pos-item" wx:for="{{positionList}}" wx:key="code">
      <view class="sim-pos-top">
        <view class="sim-pos-left">
          <text class="sim-pos-name">{{item.name}}</text>
          <text class="sub">{{item.code}} · {{item.sector || item.type}}</text>
        </view>
        <view class="sim-pos-right">
          <text class="sim-pos-profit pct-{{item.profitClass}}">{{item.profitPct}}</text>
          <text class="sub">¥{{fmt.fmtNum(item.currentValue)}}</text>
        </view>
      </view>
      <view class="sim-pos-detail">
        <text class="sub">成本: ¥{{item.costPrice}} | 现价: ¥{{item.currentPrice}} | 净值: ¥{{item.confirmedNav}}</text>
      </view>
      <view class="sim-pos-detail">
        <text class="sub">市值: ¥{{fmt.fmtNum(item.currentValue)}} | 盈亏: ¥{{fmt.fmtNum(item.profit)}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:elif="{{!loading}}">
    <view class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="sub" wx:if="{{syncError}}">{{syncError}}</text>
      <text class="sub" wx:else>当前暂无自动持仓，后续会由程序按既定逻辑自动交易并展示</text>
    </view>
  </view>

  <!-- ====== 交易记录 ====== -->
  <view class="card">
    <view class="card-header sec-toggle" data-key="secLog" bindtap="toggleSection">
      <text class="title">📋 交易记录</text>
      <text class="toggle-arrow">{{secLog ? '▲' : '▼'}}</text>
    </view>

    <view wx:if="{{secLog}}">
      <view wx:if="{{tradeLog.length === 0}}" class="empty-state">
        <text class="sub">暂无交易记录</text>
      </view>
      <view wx:else>
        <view class="sim-log-item" wx:for="{{tradeLog}}" wx:key="id">
          <view class="sim-log-row1">
            <text class="sim-log-action sim-log-{{item.action}}">{{item.action === 'buy' ? '买入' : '卖出'}}</text>
            <text class="sim-log-name">{{item.name}}</text>
            <text class="sim-log-code sub">{{item.code}}</text>
            <text class="sim-log-amount {{item.action === 'buy' ? 'pct-down' : 'pct-up'}}">
              {{item.action === 'buy' ? '-' : '+'}}¥{{fmt.fmtNum(item.amount)}}
            </text>
          </view>
          <view class="sim-log-row2">
            <text class="sub">{{item.date}}</text>
            <text class="sub sim-log-dot">·</text>
            <text class="sub sim-log-sector">{{item.sector}}</text>
          </view>
          <view class="sim-log-row-tags" wx:if="{{item.sizingLabel}}">
            <text class="sim-trade-chip sim-trade-chip-accent">{{item.sizingLabel}}</text>
          </view>
          <view class="sim-log-row3" wx:if="{{item.reason}}">
            <text class="sim-log-reason">{{item.reason}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 周复盘 ====== -->
  <view class="card">
    <view class="card-header sec-toggle" data-key="secReview" bindtap="toggleSection">
      <text class="title">📊 AI周复盘</text>
      <text class="toggle-arrow">{{secReview ? '▲' : '▼'}}</text>
    </view>

    <view wx:if="{{secReview}}">
      <view wx:if="{{weeklyReviews.length === 0}}" class="empty-state">
        <text class="sub">暂无复盘记录，系统会在每周五 15:10 自动生成</text>
      </view>
      <view wx:else>
        <view class="sim-review-item" wx:for="{{weeklyReviews}}" wx:key="id">
          <view class="sim-review-header" data-idx="{{index}}" bindtap="toggleReviewDetail">
            <view class="sim-review-left">
              <text class="sim-review-week">{{item.weekStart}} ~ {{item.weekEnd}}</text>
              <text class="sim-review-return pct-{{item.returnClass}}">{{item.returnPct}}</text>
            </view>
            <text class="toggle-arrow">{{item.showDetail ? '▲' : '▼'}}</text>
          </view>

          <view wx:if="{{item.showDetail && item.aiReview}}" class="sim-review-body">
            <view wx:if="{{item.aiReview.summary}}" class="sim-review-section">
              <text class="sim-review-section-title">📌 总结</text>
              <text class="sim-review-text">{{item.aiReview.summary}}</text>
            </view>

            <view wx:if="{{item.aiReview.performance}}" class="sim-review-section">
              <text class="sim-review-section-title">📈 表现</text>
              <text class="sim-review-text" wx:if="{{item.aiReview.performance.totalReturn}}">收益率: {{item.aiReview.performance.totalReturn}}</text>
              <text class="sim-review-text" wx:if="{{item.aiReview.performance.bestTrade}}">最佳交易: {{item.aiReview.performance.bestTrade}}</text>
              <text class="sim-review-text" wx:if="{{item.aiReview.performance.worstTrade}}">最差交易: {{item.aiReview.performance.worstTrade}}</text>
            </view>

            <view wx:if="{{item.aiReview.analysis}}" class="sim-review-section">
              <text class="sim-review-section-title">🔍 分析</text>
              <text class="sim-review-text">{{item.aiReview.analysis}}</text>
            </view>

            <view wx:if="{{item.aiReview.lessons && item.aiReview.lessons.length > 0}}" class="sim-review-section">
              <text class="sim-review-section-title">💡 经验教训</text>
              <text class="sim-review-text" wx:for="{{item.aiReview.lessons}}" wx:for-item="lesson" wx:key="*this">• {{lesson}}</text>
            </view>

            <view wx:if="{{item.aiReview.nextWeekStrategy}}" class="sim-review-section">
              <text class="sim-review-section-title">🎯 下周策略</text>
              <text class="sim-review-text">{{item.aiReview.nextWeekStrategy}}</text>
            </view>

            <view wx:if="{{item.aiReview.optimizationHints}}" class="sim-review-section">
              <text class="sim-review-section-title">⚡ 优化建议</text>
              <text class="sim-review-text">{{item.aiReview.optimizationHints}}</text>
            </view>

            <view wx:if="{{item.trades && item.trades.length > 0}}" class="sim-review-section">
              <text class="sim-review-section-title">🗂️ 交易快照</text>
              <view class="sim-review-trade-item" wx:for="{{item.trades}}" wx:key="id">
                <view class="sim-review-trade-top">
                  <text class="sim-log-action sim-log-{{item.action}}">{{item.action === 'buy' ? '买入' : '卖出'}}</text>
                  <text class="sim-review-trade-name">{{item.name}}</text>
                  <text class="sim-review-trade-amount">{{item.action === 'buy' ? '-' : '+'}}¥{{fmt.fmtNum(item.amount)}}</text>
                </view>
                <view class="sim-review-trade-meta">
                  <text class="sub">{{item.date}}</text>
                  <text class="sub">{{item.code}}</text>
                  <text class="sub">{{item.aiSource}}</text>
                </view>
                <view class="sim-week-trade-tags" wx:if="{{item.sizingLabel}}">
                  <text class="sim-trade-chip sim-trade-chip-accent">{{item.sizingLabel}}</text>
                </view>
                <text class="sim-review-text" wx:if="{{item.reason}}">{{item.reason}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 收益日历 ====== -->
  <view class="card">
    <view class="card-header">
      <text class="title">📅 收益日历</text>
      <view class="cal-month-pnl pct-{{calMonthPnlClass}}" wx:if="{{calMonthPnl}}">
        <text class="sub">本月累计 </text>
        <text class="cal-month-pnl-val">{{fmt.fmtNum(calMonthPnl)}}</text>
      </view>
    </view>

    <!-- 月份导航 -->
    <view class="cal-nav">
      <text class="cal-nav-btn" bindtap="calPrevMonth">◀</text>
      <text class="cal-nav-title" bindtap="calToday">{{calTitle}}</text>
      <text class="cal-nav-btn" bindtap="calNextMonth">▶</text>
    </view>

    <!-- 星期头 -->
    <view class="cal-weekday-row">
      <text class="cal-weekday cal-weekend">日</text>
      <text class="cal-weekday">一</text>
      <text class="cal-weekday">二</text>
      <text class="cal-weekday">三</text>
      <text class="cal-weekday">四</text>
      <text class="cal-weekday">五</text>
      <text class="cal-weekday cal-weekend">六</text>
    </view>

    <!-- 日历网格 -->
    <view class="cal-grid">
      <view class="cal-week-row" wx:for="{{calWeeks}}" wx:key="index" wx:for-item="week">
        <view class="cal-cell {{cell.inMonth ? '' : 'cal-cell-out'}} {{cell.isToday ? 'cal-cell-today' : ''}} {{calSelectedDate === cell.date ? 'cal-cell-selected' : ''}} {{cell.hasData ? 'cal-cell-data' : ''}}"
              wx:for="{{week}}" wx:for-item="cell" wx:key="date"
              data-date="{{cell.date}}" data-has="{{cell.hasData}}" bindtap="calSelectDate">
          <text class="cal-day">{{cell.day}}</text>
          <text class="cal-pnl pct-{{cell.pnlClass}}" wx:if="{{cell.hasData}}">{{cell.pnlStr}}</text>
        </view>
      </view>
    </view>

    <!-- 选中日期详情 -->
    <view class="cal-detail" wx:if="{{calSelectedDetail}}">
      <view class="cal-detail-header">
        <text class="cal-detail-date">{{calSelectedDate}}</text>
        <text class="cal-detail-pnl pct-{{calSelectedDetail.dailyPnl >= 0 ? (calSelectedDetail.dailyPnl > 0 ? 'up' : 'flat') : 'down'}}">
          {{calSelectedDetail.dailyPnl >= 0 ? '+' : ''}}{{fmt.fmtNum(calSelectedDetail.dailyPnl)}} ({{calSelectedDetail.dailyPct >= 0 ? '+' : ''}}{{calSelectedDetail.dailyPct}}%)
        </text>
      </view>
      <view class="cal-detail-row">
        <text class="sub">总资产</text>
        <text class="cal-detail-val">¥{{fmt.fmtNum(calSelectedDetail.totalValue)}}</text>
      </view>
      <view class="cal-detail-row">
        <text class="sub">现金</text>
        <text class="cal-detail-val">¥{{fmt.fmtNum(calSelectedDetail.cash)}}</text>
      </view>
      <view class="cal-detail-row">
        <text class="sub">持仓市值</text>
        <text class="cal-detail-val">¥{{fmt.fmtNum(calSelectedDetail.positionValue)}}</text>
      </view>
      <!-- 持仓明细 -->
      <view wx:if="{{calSelectedDetail.positions && calSelectedDetail.positions.length > 0}}" class="cal-detail-positions">
        <view class="cal-detail-pos-header">
          <text class="cal-pos-name">名称</text>
          <text class="cal-pos-nav">净值</text>
          <text class="cal-pos-shares">份额</text>
          <text class="cal-pos-val">市值</text>
        </view>
        <view class="cal-detail-pos-row" wx:for="{{calSelectedDetail.positions}}" wx:key="code">
          <text class="cal-pos-name">{{item.name}}</text>
          <text class="cal-pos-nav">{{item.price || item.nav}}</text>
          <text class="cal-pos-shares">{{fmt.fmtNum(item.shares)}}</text>
          <text class="cal-pos-val">{{fmt.fmtNum(item.value)}}</text>
        </view>
      </view>
    </view>
    <view class="cal-detail cal-empty" wx:elif="{{calSelectedDate && !calSelectedDetail}}">
      <text class="sub">{{calSelectedDate}} 无结算数据</text>
    </view>
  </view>

</view>
