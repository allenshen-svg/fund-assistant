/* ====== 模拟仓概览 ====== */
.sim-overview-card {
  position: relative;
}

.sim-reset {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--border-subtle);
  border-radius: 8rpx;
}

.sim-summary {
  margin-bottom: 20rpx;
}

.sim-summary-main {
  text-align: center;
  padding: 20rpx 0 16rpx;
}

.sim-total-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.sim-total-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-strong);
  display: block;
  margin-bottom: 8rpx;
}

.sim-return {
  font-size: 28rpx;
  font-weight: 600;
}

.sim-summary-row {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-summary-item {
  text-align: center;
}

.sim-summary-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 4rpx;
}

.sim-summary-val {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

/* ====== 结算状态 ====== */
.sim-settle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 0;
  margin-top: 12rpx;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-settle-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sim-settle-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.sim-settle-pnl {
  font-size: 28rpx;
  font-weight: 700;
}

.sim-settle-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sim-settle-date {
  font-size: 22rpx;
}

.sim-settle-btn {
  font-size: 24rpx;
  color: var(--accent);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--border-accent);
  border-radius: 8rpx;
  font-weight: 500;
}

/* ====== 结算历史列表 ====== */
.sim-settle-list {
  margin-top: 8rpx;
}

.sim-settle-list-header {
  display: flex;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.sim-settle-list-header text {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.sim-settle-list-row {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-faint);
}

.sim-settle-list-row text {
  font-size: 24rpx;
}

.sim-settle-col-date {
  flex: 2.5;
}

.sim-settle-col-val {
  flex: 2.5;
  text-align: right;
}

.sim-settle-col-pnl {
  flex: 2;
  text-align: right;
}

.sim-settle-col-pct {
  flex: 1.5;
  text-align: right;
}

/* ====== 操作按钮 ====== */
.sim-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.sim-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  border: 1rpx solid var(--border-subtle);
}

.sim-btn-buy {
  background: rgba(239,68,68,0.08);
  border-color: rgba(239,68,68,0.2);
}

.sim-btn-sell {
  background: rgba(34,197,94,0.08);
  border-color: rgba(34,197,94,0.2);
}

.sim-btn-review {
  background: rgba(108,138,255,0.08);
  border-color: rgba(108,138,255,0.2);
}

.sim-btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.sim-btn-text {
  font-size: 24rpx;
  color: var(--text);
  font-weight: 500;
}

/* ====== 持仓列表 ====== */
.sim-pos-item {
  border-top: 1rpx solid var(--border-subtle);
  padding: 16rpx 0;
}

.sim-pos-item:first-child {
  border-top: none;
}

.sim-pos-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.sim-pos-left {
  flex: 1;
}

.sim-pos-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.sim-pos-right {
  text-align: right;
}

.sim-pos-profit {
  font-size: 30rpx;
  font-weight: 700;
}

.sim-pos-detail {
  margin-top: 8rpx;
}

.sim-pos-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 8rpx;
}

.sim-pos-btn {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.sim-pos-btn-add {
  color: #ef4444;
  background: rgba(239,68,68,0.1);
}

.sim-pos-btn-sell {
  color: #22c55e;
  background: rgba(34,197,94,0.1);
}

/* ====== 交易记录 ====== */
.sim-log-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-log-item:first-child {
  border-top: none;
}

.sim-log-left {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.sim-log-action {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.sim-log-buy {
  color: #ef4444;
  background: rgba(239,68,68,0.12);
}

.sim-log-sell {
  color: #22c55e;
  background: rgba(34,197,94,0.12);
}

.sim-log-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.sim-log-right {
  text-align: right;
  flex-shrink: 0;
}

.sim-log-amount {
  font-size: 26rpx;
  font-weight: 600;
}

.sim-log-reason {
  font-size: 22rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ====== 折叠 ====== */
.sec-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-arrow {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ====== 周复盘 ====== */
.sim-review-item {
  border-top: 1rpx solid var(--border-subtle);
  padding: 12rpx 0;
}

.sim-review-item:first-child {
  border-top: none;
}

.sim-review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sim-review-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sim-review-week {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.sim-review-return {
  font-size: 26rpx;
  font-weight: 700;
}

.sim-review-body {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--elevated);
  border-radius: 12rpx;
}

.sim-review-section {
  margin-bottom: 16rpx;
}

.sim-review-section:last-child {
  margin-bottom: 0;
}

.sim-review-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 8rpx;
}

.sim-review-text {
  font-size: 24rpx;
  color: var(--text-body);
  display: block;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

/* ====== 弹出面板 ====== */
.sim-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
}

.sim-modal {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.sim-modal-show {
  transform: translateY(0);
}

.sim-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.sim-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-modal-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.sim-modal-footer {
  padding: 16rpx 32rpx 48rpx;
  flex-shrink: 0;
}

/* ====== 买入面板 ====== */
.sim-buy-tabs {
  display: flex;
  padding: 16rpx 32rpx;
  gap: 16rpx;
  flex-shrink: 0;
}

.sim-buy-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: var(--text-muted);
  border-radius: 12rpx;
  background: var(--elevated);
  font-weight: 500;
}

.sim-buy-tab.active {
  color: var(--text-strong);
  background: var(--accent-bg);
  font-weight: 700;
}

.sim-pick-time {
  padding: 0 32rpx 8rpx;
}

.sim-pick-list {
  max-height: 40vh;
  padding: 0 32rpx;
  flex: 1;
  overflow: hidden;
}

.sim-pick-item {
  padding: 16rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--border-subtle);
  margin-bottom: 12rpx;
  transition: all 0.2s;
}

.sim-pick-item.sim-pick-selected {
  border-color: var(--accent);
  background: var(--accent-bg);
}

.sim-pick-info {
  margin-bottom: 6rpx;
}

.sim-pick-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.sim-pick-reason {
  margin-top: 4rpx;
}

/* ====== 买入金额输入 ====== */
.sim-buy-input-row {
  padding: 16rpx 32rpx;
  border-top: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.sim-buy-target {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
  display: block;
  margin-bottom: 12rpx;
}

.sim-buy-input-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--input-bg);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
}

.sim-buy-yen {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.sim-buy-input {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-buy-quick-btns {
  display: flex;
  gap: 12rpx;
}

.sim-quick-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text);
  padding: 8rpx 0;
  background: var(--elevated);
  border-radius: 8rpx;
  border: 1rpx solid var(--border-subtle);
}

.sim-confirm-btn {
  width: 100%;
  text-align: center;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
}

.sim-confirm-btn.disabled {
  opacity: 0.4;
}

/* ====== 卖出面板 ====== */
.sim-sell-loading {
  padding: 60rpx 0;
  text-align: center;
}

.sim-sell-content {
  max-height: 65vh;
  padding: 0 32rpx 32rpx;
  flex: 1;
  overflow: hidden;
}

.sim-sell-overview {
  padding: 16rpx 20rpx;
  background: var(--elevated);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.sim-sell-overview-text {
  font-size: 26rpx;
  color: var(--text-body);
  line-height: 1.6;
}

.sim-sell-risk {
  padding: 12rpx 20rpx;
  background: rgba(251,191,36,0.1);
  border-radius: 12rpx;
  border-left: 6rpx solid #fbbf24;
  margin-bottom: 16rpx;
}

.sim-sell-risk-text {
  font-size: 24rpx;
  color: #fbbf24;
  line-height: 1.5;
}

.sim-sell-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin: 16rpx 0 12rpx;
}

.sim-sell-item {
  background: var(--elevated);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #f87171;
}

.sim-sell-item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.sim-sell-item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.sim-sell-item-action {
  text-align: right;
}

.sim-sell-urgency {
  font-size: 22rpx;
  display: block;
  margin-bottom: 4rpx;
}

.sim-sell-pct {
  font-size: 24rpx;
  font-weight: 600;
  color: #f87171;
}

.sim-sell-item-reason {
  margin-bottom: 12rpx;
}

.sim-sell-item-btn {
  text-align: center;
  padding: 12rpx 0;
  background: rgba(239,68,68,0.12);
  color: #ef4444;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 10rpx;
}

.sim-sell-hold {
  margin-top: 16rpx;
}

.sim-sell-hold-text {
  font-size: 24rpx;
  color: var(--text-body);
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: var(--elevated);
  border-radius: 12rpx;
}

/* ====== 涨跌色 ====== */
.pct-up { color: #ef4444; }
.pct-down { color: #22c55e; }
.pct-flat { color: var(--text-muted); }

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.loading-tip {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}
