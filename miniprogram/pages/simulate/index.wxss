/* ====== 模拟仓概览 ====== */
.sim-overview-card {
  position: relative;
}

/* ====== 加载骨架屏 ====== */
.sim-skeleton {
  padding: 24rpx 0;
}
.skeleton-line {
  height: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, rgba(0,0,0,0.06) 25%, rgba(0,0,0,0.10) 50%, rgba(0,0,0,0.06) 75%);
  background-size: 400% 100%;
  animation: shimmer 1.5s ease infinite;
  margin-bottom: 20rpx;
}
.skeleton-w60 { width: 60%; }
.skeleton-w40 { width: 40%; }
.skeleton-w80 { width: 80%; }
@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.sim-auto-ai-tag {
  color: #d97706;
}

.sim-auto-banner {
  margin: 8rpx 0 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.10), rgba(59, 130, 246, 0.08));
  border: 1rpx solid rgba(16, 185, 129, 0.25);
}

.sim-auto-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-auto-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.sim-auto-config {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.sim-auto-config-chip {
  font-size: 21rpx;
  line-height: 1.4;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #0f766e;
  background: rgba(16, 185, 129, 0.12);
}

.sim-attrib-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.sim-attrib-item {
  width: calc((100% - 12rpx) / 2);
  box-sizing: border-box;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.04);
}

.sim-attrib-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
}

.sim-attrib-value {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-attrib-section {
  margin-top: 12rpx;
}

.sim-attrib-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-strong);
  margin-bottom: 6rpx;
}

.sim-attrib-text {
  display: block;
  font-size: 23rpx;
  line-height: 1.8;
  color: var(--text);
}

.sim-attrib-pair {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sim-attrib-pair-item {
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--text-muted);
}

.sim-factor-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sim-factor-item {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.04);
}

.sim-factor-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sim-factor-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-factor-score {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 700;
}

.sim-factor-bar {
  margin-top: 8rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(108, 138, 255, 0.10);
  overflow: hidden;
}

.sim-factor-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #34d399, #60a5fa);
}

.sim-factor-summary {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.sim-week-trade-item {
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-week-trade-item:first-child {
  border-top: none;
}

.sim-week-trade-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sim-week-trade-name {
  flex: 1;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-week-trade-amount {
  font-size: 25rpx;
  font-weight: 700;
}

.sim-week-trade-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  margin-top: 8rpx;
}

.sim-week-trade-tags,
.sim-log-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.sim-trade-chip {
  display: inline-flex;
  align-items: center;
  font-size: 21rpx;
  line-height: 1.4;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.sim-trade-chip-accent {
  color: #3557c8;
  background: rgba(108, 138, 255, 0.12);
}

.sim-week-trade-reason {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--text);
}

.sim-summary {
  margin-bottom: 20rpx;
}

.sim-summary-main {
  text-align: center;
  padding: 20rpx 0 16rpx;
}

.sim-total-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.sim-total-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-strong);
  display: block;
  margin-bottom: 8rpx;
}

.sim-return {
  font-size: 28rpx;
  font-weight: 600;
}

.sim-summary-row {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-summary-item {
  text-align: center;
}

.sim-summary-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 4rpx;
}

.sim-summary-val {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

/* ====== 结算状态 ====== */
.sim-settle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 0;
  margin-top: 12rpx;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-settle-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sim-settle-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.sim-settle-pnl {
  font-size: 28rpx;
  font-weight: 700;
}

.sim-settle-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sim-settle-date {
  font-size: 22rpx;
}

.sim-settle-btn {
  font-size: 24rpx;
  color: var(--accent);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--border-accent);
  border-radius: 8rpx;
  font-weight: 500;
}

/* ====== 收益日历 ====== */
.cal-month-pnl {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.cal-month-pnl-val {
  font-size: 26rpx;
  font-weight: 700;
}

.cal-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 20rpx;
}

.cal-nav-btn {
  font-size: 28rpx;
  color: var(--accent);
  padding: 8rpx 20rpx;
}

.cal-nav-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.cal-weekday-row {
  display: flex;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.cal-weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.cal-weekend {
  color: var(--text-muted);
  opacity: 0.6;
}

.cal-grid {
  padding: 4rpx 0;
}

.cal-week-row {
  display: flex;
}

.cal-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  min-height: 80rpx;
  border-radius: 8rpx;
  transition: background 0.2s;
}

.cal-cell-out {
  opacity: 0.3;
}

.cal-cell-today {
  background: rgba(108,138,255,0.1);
  border: 1rpx solid rgba(108,138,255,0.3);
}

.cal-cell-selected {
  background: rgba(108,138,255,0.18);
  border: 2rpx solid var(--accent);
}

.cal-cell-data {
}

.cal-day {
  font-size: 24rpx;
  color: var(--text);
  font-weight: 500;
  line-height: 1.2;
}

.cal-cell-out .cal-day {
  color: var(--text-muted);
}

.cal-pnl {
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-top: 2rpx;
}

/* 详情面板 */
.cal-detail {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--bg-card-inner, rgba(108,138,255,0.04));
  border-radius: 12rpx;
  border: 1rpx solid var(--border-subtle);
}

.cal-empty {
  text-align: center;
  padding: 20rpx;
}

.cal-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid var(--border-subtle);
}

.cal-detail-date {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.cal-detail-pnl {
  font-size: 28rpx;
  font-weight: 700;
}

.cal-detail-row {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
}

.cal-detail-val {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.cal-detail-positions {
  margin-top: 12rpx;
  border-top: 1rpx solid var(--border-subtle);
  padding-top: 8rpx;
}

.cal-detail-pos-header {
  display: flex;
  padding: 6rpx 0;
  border-bottom: 1rpx solid var(--border-faint);
}

.cal-detail-pos-header text {
  font-size: 20rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.cal-detail-pos-row {
  display: flex;
  padding: 6rpx 0;
}

.cal-detail-pos-row text {
  font-size: 22rpx;
  color: var(--text);
}

.cal-pos-name {
  flex: 3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cal-pos-nav {
  flex: 2;
  text-align: right;
}

.cal-pos-shares {
  flex: 2;
  text-align: right;
}

.cal-pos-val {
  flex: 2.5;
  text-align: right;
}

/* ====== 持仓列表 ====== */
.sim-pos-item {
  border-top: 1rpx solid var(--border-subtle);
  padding: 16rpx 0;
}

.sim-pos-item:first-child {
  border-top: none;
}

.sim-pos-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.sim-pos-left {
  flex: 1;
}

.sim-pos-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.sim-pos-right {
  text-align: right;
}

.sim-pos-profit {
  font-size: 30rpx;
  font-weight: 700;
}

.sim-pos-detail {
  margin-top: 8rpx;
}

/* ====== 交易记录 ====== */
.sim-log-item {
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-subtle);
}

.sim-log-item:first-child {
  border-top: none;
}

.sim-log-row1 {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sim-log-action {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
  flex-shrink: 0;
  line-height: 1.4;
}

.sim-log-buy {
  color: #ef4444;
  background: rgba(239,68,68,0.12);
}

.sim-log-sell {
  color: #22c55e;
  background: rgba(34,197,94,0.12);
}

.sim-log-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  flex-shrink: 0;
}

.sim-log-code {
  font-size: 22rpx;
  flex-shrink: 0;
}

.sim-log-amount {
  font-size: 26rpx;
  font-weight: 600;
  margin-left: auto;
  flex-shrink: 0;
  white-space: nowrap;
}

.sim-log-row2 {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

.sim-log-dot {
  flex-shrink: 0;
}

.sim-log-sector {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sim-log-row3 {
  margin-top: 8rpx;
  padding-left: 4rpx;
}

.sim-log-reason {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ====== 折叠 ====== */
.sec-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-arrow {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ====== 周复盘 ====== */
.sim-review-item {
  border-top: 1rpx solid var(--border-subtle);
  padding: 12rpx 0;
}

.sim-review-item:first-child {
  border-top: none;
}

.sim-review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sim-review-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sim-review-week {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.sim-review-return {
  font-size: 26rpx;
  font-weight: 700;
}

.sim-review-body {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--elevated);
  border-radius: 12rpx;
}

.sim-review-section {
  margin-bottom: 16rpx;
}

.sim-review-section:last-child {
  margin-bottom: 0;
}

.sim-review-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 8rpx;
}

.sim-review-text {
  font-size: 24rpx;
  color: var(--text-body);
  display: block;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.sim-review-trade-item {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(15, 23, 42, 0.04);
}

.sim-review-trade-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sim-review-trade-name {
  flex: 1;
  font-size: 25rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-review-trade-amount {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text);
}

.sim-review-trade-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  margin-top: 8rpx;
}

/* ====== 涨跌色 ====== */
.pct-up { color: #ef4444; }
.pct-down { color: #22c55e; }
.pct-flat { color: var(--text-muted); }

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.loading-tip {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}
