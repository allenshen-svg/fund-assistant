.stock-page {
  padding-bottom: 80rpx;
}

.stock-hero {
  background: radial-gradient(circle at top right, rgba(108,138,255,0.22), transparent 36%), linear-gradient(145deg, var(--surface) 0%, var(--surface-alt) 100%);
}

.stock-hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.stock-hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-strong);
}

.stock-hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

.stock-hero-status {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.18);
  border: 1rpx solid var(--border-accent-light);
}

.stock-status-main {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.stock-status-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-sub);
}

.stock-hero-tip {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.stock-notify-box {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.stock-notify-main {
  flex: 1;
}

.stock-notify-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.stock-notify-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-sub);
}

.stock-notify-btn {
  min-width: 190rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
}

.stock-tip-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #fbbf24;
}

.stock-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  text-align: center;
}

.stock-loading-orbit {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(108,138,255,0.18);
  border-top-color: var(--accent);
  animation: stockSpin 1s linear infinite;
}

.stock-loading-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.stock-loading-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

@keyframes stockSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.sim-screen-summary {
  padding: 8rpx 0 16rpx;
  border-bottom: 1rpx solid var(--border-subtle);
  margin-bottom: 8rpx;
}

.sim-screen-summary-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--text-strong);
}

.sim-screen-strategy {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-muted);
  margin-top: 6rpx;
}

.sim-screen-meta {
  display: block;
  margin-top: 8rpx;
}

.sim-screen-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.sim-screen-item:last-child {
  border-bottom: none;
}

.sim-screen-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.sim-screen-left,
.sim-screen-right {
  display: flex;
  flex-direction: column;
}

.sim-screen-right {
  align-items: flex-end;
}

.sim-screen-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.sim-screen-score {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--accent);
}

.sim-screen-confidence {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.sim-screen-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.sim-screen-tag {
  font-size: 22rpx;
  line-height: 1.4;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.sim-screen-tag-signal {
  color: #3557c8;
  background: rgba(108, 138, 255, 0.12);
}

.sim-screen-tag-risk {
  min-width: 92rpx;
  text-align: center;
}

.sim-risk-low {
  color: #147a52;
  background: rgba(34, 197, 94, 0.14);
}

.sim-risk-mid {
  color: #a16207;
  background: rgba(245, 158, 11, 0.16);
}

.sim-risk-high {
  color: #b42318;
  background: rgba(248, 113, 113, 0.16);
}

.sim-screen-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 12rpx;
}

.sim-screen-reason {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text);
  margin-top: 12rpx;
}

.sim-screen-advice {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--accent);
  margin-top: 8rpx;
  font-weight: 600;
}

.sim-screen-plan {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 16rpx;
  margin-top: 10rpx;
}

.sim-screen-plan-item {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-muted);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(15, 23, 42, 0.05);
}

.sim-screen-entry,
.sim-screen-risk {
  display: block;
  margin-top: 8rpx;
}

.stock-pick-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 14rpx;
}

.stock-pick-btn {
  min-width: 180rpx;
  padding: 10rpx 18rpx;
  background: linear-gradient(135deg, #6c8aff 0%, #4f7cff 100%);
}